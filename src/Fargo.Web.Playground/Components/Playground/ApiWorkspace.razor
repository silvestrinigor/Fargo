    private void SelectArticle(ArticleDto article)
    {
        selectedArticle = article;
    }

    private void SelectItem(ItemDto item)
    {
        selectedItem = item;
    }

    private void SelectUser(UserDto user)
    {
        selectedUser = user;
    }

    private void SelectUserGroup(UserGroupDto userGroup)
    {
        selectedUserGroup = userGroup;
    }

    private void SelectPartition(PartitionDto partition)
    {
        selectedPartition = partition;
    }

    private void CloseDetailsPane()
    {
        switch (Resource)
        {
            case PlaygroundResource.Articles:
                selectedArticle = null;
                if (!HasArticleGrid && result?.Payload is ArticleDto)
                {
                    result = null;
                }
                break;
            case PlaygroundResource.Items:
                selectedItem = null;
                if (!HasItemGrid && result?.Payload is ItemDto)
                {
                    result = null;
                }
                break;
            case PlaygroundResource.Users:
                selectedUser = null;
                if (!HasUserGrid && result?.Payload is UserDto)
                {
                    result = null;
                }
                break;
            case PlaygroundResource.UserGroups:
                selectedUserGroup = null;
                if (!HasUserGroupGrid && result?.Payload is UserGroupDto)
                {
                    result = null;
                }
                break;
            case PlaygroundResource.Partitions:
                selectedPartition = null;
                if (!HasPartitionGrid && result?.Payload is PartitionDto)
                {
                    result = null;
                }
                break;
        }
    }

    private static string ItemDisplayName(ItemDto item)
        => $"Article {item.ArticleGuid.ToString("D")[..8]}";

    private static string FullName(UserDto user)
    {
        var parts = new[] { user.FirstName, user.LastName }
            .Where(static value => !string.IsNullOrWhiteSpace(value))
            .ToArray();

        return parts.Length == 0 ? "None" : string.Join(' ', parts);
    }

    private static string DisplayValue(string? value)
        => string.IsNullOrWhiteSpace(value) ? "None" : value;

    private static string FormatDuration(TimeSpan? value)
        => value is null ? "None" : value.Value.ToString("c", CultureInfo.InvariantCulture);

    private static string FormatUnit(UnitValueDto? value)
        => value is null ? "None" : $"{value.Value.ToString("G", CultureInfo.InvariantCulture)} {value.Unit}";

    private RenderFragment DetailValue(string label, string? value) => @<div class="detail-item">
        <span>@label</span>
        <strong>@DisplayValue(value)</strong>
    </div>;

    private RenderFragment ActiveBadge(bool isActive) => @<FluentBadge Class="@(isActive ? "state-badge active" : "state-badge inactive")">
        @(isActive ? "Active" : "Inactive")
    </FluentBadge>;

    private RenderFragment ColorSwatch(string? color) => @<div class="color-display">
        @if (string.IsNullOrWhiteSpace(color))
        {
            <span class="color-swatch empty"></span>
            <span>None</span>
        }
        else
        {
            <span class="color-swatch" style="@($"background-color: {color}")"></span>
            <code class="color-value">@color</code>
        }
    </div>;

    private RenderFragment GuidChip(Guid? guid) => @<code class="@($"guid-chip {(guid is null ? "empty" : string.Empty)}")">
        @(guid?.ToString("D") ?? "None")
    </code>;

    private RenderFragment GuidCollection(string title, IEnumerable<Guid> guids)
    {
        var values = guids.ToArray();

        return @<section class="detail-section">
            <h4>@title</h4>
            <div class="chip-list">
                @if (values.Length == 0)
                {
                    <span class="empty-value">None</span>
                }
                else
                {
                    @foreach (var guid in values)
                    {
                        @GuidChip(guid)
                    }
                }
            </div>
        </section>;
    }

    private RenderFragment PermissionCollection(string title, IEnumerable<ActionType> permissions)
    {
        var values = permissions.ToArray();

        return @<section class="detail-section">
            <h4>@title</h4>
            <div class="chip-list">
                @if (values.Length == 0)
                {
                    <span class="empty-value">None</span>
                }
                else
                {
                    @foreach (var permission in values)
                    {
                        <FluentBadge Appearance="Appearance.Neutral">@permission</FluentBadge>
                    }
                }
            </div>
        </section>;
    }

    private RenderFragment EditedBy(Guid? editedByGuid) => @<section class="detail-section">
        <h4>Edited by</h4>
        @GuidChip(editedByGuid)
    </section>;

