    private static IReadOnlyCollection<Guid> ParseGuidList(string? value, string label)
        => SplitLines(value)
            .SelectMany(static line => line.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
            .Select((item, index) => RequiredGuid(item, $"{label} item {index + 1}"))
            .Distinct()
            .ToArray();

    private static Guid RequiredGuid(string? value, string label)
        => Guid.TryParse(value, out var guid)
            ? guid
            : throw new InvalidOperationException($"{label} is required and must be a GUID.");

    private static Guid? ParseNullableGuid(string? value, string label)
        => string.IsNullOrWhiteSpace(value)
            ? null
            : RequiredGuid(value, label);

    private static string RequiredText(string? value, string label)
        => string.IsNullOrWhiteSpace(value)
            ? throw new InvalidOperationException($"{label} is required.")
            : value.Trim();

    private static string? OptionalText(bool include, string? value)
        => include ? value ?? string.Empty : null;

    private static string? Clean(string? value)
        => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static double RequiredDouble(string? value, string label)
        => double.TryParse(value, NumberStyles.Float, CultureInfo.InvariantCulture, out var parsed)
            ? parsed
            : throw new InvalidOperationException($"{label} is required and must be a number.");

    private static TimeSpan RequiredTimeSpan(string? value, string label)
        => TimeSpan.TryParse(value, CultureInfo.InvariantCulture, out var parsed)
            ? parsed
            : throw new InvalidOperationException($"{label} is required and must be a TimeSpan.");

    private static TimeSpan? ParseNullableTimeSpan(string? value, string label)
        => string.IsNullOrWhiteSpace(value) ? null : RequiredTimeSpan(value, label);

    private static int? ParseNullableInt(string? value, string label)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        if (!int.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsed))
        {
            throw new InvalidOperationException($"{label} must be an integer.");
        }

        return parsed;
    }

    private static DateTimeOffset? ParseNullableDateTimeOffset(string? value, string label)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        if (!DateTimeOffset.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.AssumeLocal, out var parsed))
        {
            throw new InvalidOperationException($"{label} must be a valid date/time.");
        }

        return parsed;
    }

    private static bool? OptionalBool(bool include, bool value)
        => include ? value : null;

    private static IReadOnlyCollection<string> SplitLines(string? value)
        => string.IsNullOrWhiteSpace(value)
            ? []
            : value.Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

    private static TextFieldType ToTextFieldType(string type)
        => type.ToLowerInvariant() switch
        {
            "password" => TextFieldType.Password,
            "color" => TextFieldType.Color,
            "number" => TextFieldType.Number,
            "search" => TextFieldType.Search,
            "email" => TextFieldType.Email,
            "tel" => TextFieldType.Tel,
            "url" => TextFieldType.Url,
            _ => TextFieldType.Text
        };

    private static DateTime? GetDatePart(string? value)
        => DateTimeOffset.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.AssumeLocal, out var parsed)
            ? parsed.LocalDateTime.Date
            : null;

    private static DateTime? GetTimePart(string? value)
        => DateTimeOffset.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.AssumeLocal, out var parsed)
            ? new DateTime(2000, 1, 1, parsed.LocalDateTime.Hour, parsed.LocalDateTime.Minute, parsed.LocalDateTime.Second)
            : null;

    private static string? SetDatePart(string? currentValue, DateTime? date)
    {
        if (date is null)
        {
            return null;
        }

        var time = GetTimePart(currentValue)?.TimeOfDay ?? TimeSpan.Zero;
        return FormatDateTimeOffset(date.Value.Date.Add(time));
    }

    private static string? SetTimePart(string? currentValue, DateTime? time)
    {
        if (time is null && string.IsNullOrWhiteSpace(currentValue))
        {
            return null;
        }

        var date = GetDatePart(currentValue) ?? DateTime.Today;
        return FormatDateTimeOffset(date.Date.Add(time?.TimeOfDay ?? TimeSpan.Zero));
    }

    private static string FormatDateTimeOffset(DateTime localDateTime)
        => new DateTimeOffset(DateTime.SpecifyKind(localDateTime, DateTimeKind.Local))
            .ToString("yyyy-MM-ddTHH:mm:sszzz", CultureInfo.InvariantCulture);

    private static string? GetDurationPart(string? value, DurationPart part)
    {
        if (!TimeSpan.TryParse(value, CultureInfo.InvariantCulture, out var duration))
        {
            return null;
        }

        var numericValue = part switch
        {
            DurationPart.Days => duration.Days,
            DurationPart.Hours => duration.Hours,
            DurationPart.Minutes => duration.Minutes,
            _ => 0
        };

        return numericValue.ToString(CultureInfo.InvariantCulture);
    }

    private static string? SetDurationPart(string? currentValue, DurationPart part, string? value)
    {
        var current = TimeSpan.TryParse(currentValue, CultureInfo.InvariantCulture, out var parsed)
            ? parsed
            : TimeSpan.Zero;

        var days = current.Days;
        var hours = current.Hours;
        var minutes = current.Minutes;
        var newValue = int.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsedValue)
            ? Math.Max(0, parsedValue)
            : 0;

        switch (part)
        {
            case DurationPart.Days:
                days = newValue;
                break;
            case DurationPart.Hours:
                hours = newValue;
                break;
            case DurationPart.Minutes:
                minutes = newValue;
                break;
        }

        if (days == 0 && hours == 0 && minutes == 0)
        {
            return null;
        }

        return new TimeSpan(days, hours, minutes, 0).ToString("c", CultureInfo.InvariantCulture);
    }

    private static void RequireConfirmation(ConfirmGuidForm form)
    {
        if (!form.Confirm)
        {
            throw new InvalidOperationException("Confirm the delete operation before submitting.");
        }
    }

    private static void TogglePermission(HashSet<ActionType> set, ActionType action, bool isSelected)
    {
        if (isSelected)
        {
            set.Add(action);
        }
        else
        {
            set.Remove(action);
        }
    }

    private void LoadArticleIntoPatch(ArticleDto article)
    {
        selectedArticle = article;
        selectedArticleOperation = OperationIds.Patch;
        articlePatch.Guid = article.Guid.ToString("D");
        articlePatch.Name = article.Name;
        articlePatch.Description = article.Description;
        articlePatch.PartitionsText = string.Join(Environment.NewLine, article.Partitions);
        articlePatch.IsActive = article.IsActive;
        OpenActionDialog(OperationIds.Patch);
    }

    private void LoadItemIntoUpdate(ItemDto item)
    {
        selectedItem = item;
        selectedItemOperation = OperationIds.Update;
        itemUpdate.Guid = item.Guid.ToString("D");
        itemUpdate.PartitionsText = string.Join(Environment.NewLine, item.Partitions);
        itemUpdate.ParentContainerGuid = item.ParentContainerGuid?.ToString("D") ?? string.Empty;
        itemUpdate.IsActive = item.IsActive;
        OpenActionDialog(OperationIds.Update);
    }

    private void LoadUserIntoUpdate(UserDto user)
    {
        selectedUser = user;
        selectedUserOperation = OperationIds.Update;
        userUpdate.Guid = user.Guid.ToString("D");
        userUpdate.Nameid = user.Nameid;
        userUpdate.FirstName = user.FirstName ?? string.Empty;
        userUpdate.LastName = user.LastName ?? string.Empty;
        userUpdate.Description = user.Description;
        userUpdate.PartitionsText = string.Join(Environment.NewLine, user.Partitions);
        userUpdate.UserGroupsText = string.Join(Environment.NewLine, user.UserGroups);
        userUpdate.IsActive = user.IsActive;
        userUpdate.Permissions.Clear();
        foreach (var permission in user.Permissions.Select(static permission => permission.Action))
        {
            userUpdate.Permissions.Add(permission);
        }
        OpenActionDialog(OperationIds.Update);
    }

    private void LoadUserGroupIntoUpdate(UserGroupDto userGroup)
    {
        selectedUserGroup = userGroup;
        selectedUserGroupOperation = OperationIds.Update;
        userGroupUpdate.Guid = userGroup.Guid.ToString("D");
        userGroupUpdate.Nameid = userGroup.Nameid;
        userGroupUpdate.Description = userGroup.Description;
        userGroupUpdate.PartitionsText = string.Join(Environment.NewLine, userGroup.Partitions);
        userGroupUpdate.IsActive = userGroup.IsActive;
        userGroupUpdate.Permissions.Clear();
        foreach (var permission in userGroup.Permissions.Select(static permission => permission.Action))
        {
            userGroupUpdate.Permissions.Add(permission);
        }
        OpenActionDialog(OperationIds.Update);
    }

    private void LoadPartitionIntoUpdate(PartitionDto partition)
    {
        selectedPartition = partition;
        selectedPartitionOperation = OperationIds.Update;
        partitionUpdate.Guid = partition.Guid.ToString("D");
        partitionUpdate.Name = partition.Name;
        partitionUpdate.Description = partition.Description;
        partitionUpdate.ParentPartitionGuid = partition.ParentPartitionGuid?.ToString("D") ?? string.Empty;
        partitionUpdate.IsActive = partition.IsActive;
        OpenActionDialog(OperationIds.Update);
    }

    private static string FormatPayload(object payload)
        => payload is string text
            ? text
            : JsonSerializer.Serialize(payload, JsonOptions);

    private static JsonSerializerOptions CreateDisplayJsonOptions()
    {
        var options = FargoHttpJsonSerializerOptions.Create();
        options.WriteIndented = true;
        options.Converters.Add(new JsonStringEnumConverter());
        return options;
    }

    private RenderFragment ListQueryFields(ListQueryForm form) => @<div class="form-grid">
        @DateTimeOffsetField("Temporal as of", form.TemporalAsOf, value => form.TemporalAsOf = value)
        @IntegerField("Page", form.Page, value => form.Page = value, 1)
        @IntegerField("Limit", form.Limit, value => form.Limit = value, 1)
        @TextAreaField("Child partitions", form.ChildPartitionsText, value => form.ChildPartitionsText = value)
        @CheckboxField("Not child of any partition", form.NotChildOfAnyPartition, value => form.NotChildOfAnyPartition = value)
    </div>;

    private RenderFragment TextField(
        string label,
        string? value,
        Action<string?> setValue,
        string? placeholder = null,
        string type = "text") => @<FluentTextField
            Label="@label"
            Value="@value"
            ValueChanged="@(newValue => setValue(newValue))"
            TextFieldType="@ToTextFieldType(type)"
            Placeholder="@placeholder"
            Immediate="true"
            Class="field-control" />;

    private RenderFragment GuidField(string label, string? value, Action<string?> setValue) => TextField(label, value, setValue);

    private RenderFragment TextAreaField(string label, string? value, Action<string?> setValue) => @<FluentTextArea
        Label="@label"
        Value="@value"
        ValueChanged="@(newValue => setValue(newValue))"
        Rows="4"
        Resize="TextAreaResize.Vertical"
        Immediate="true"
        Class="field-wide field-control" />;

    private RenderFragment CheckboxField(string label, bool value, Action<bool> setValue) => @<FluentCheckbox
        Value="@value"
        ValueChanged="@(newValue => setValue(newValue))"
        Class="check-field">
        @label
    </FluentCheckbox>;

    private RenderFragment ConfirmField(bool value, Action<bool> setValue, string label) => CheckboxField(label, value, setValue);

    private RenderFragment OptionalBoolField(string label, bool include, Action<bool> setInclude, bool value, Action<bool> setValue) => @<div class="field">
        @CheckboxField($"Include {label}", include, setInclude)
        @if (include)
        {
            @CheckboxField(label, value, setValue)
        }
    </div>;

    private RenderFragment EnumField<TEnum>(string label, TEnum value, Action<TEnum> setValue)
        where TEnum : struct, Enum
        => @<FluentSelect
            TOption="string"
            Label="@label"
            Value="@value.ToString()"
            ValueChanged="@(newValue => setValue(Enum.Parse<TEnum>(newValue)))"
            Class="field-control">
            @foreach (var option in Enum.GetValues<TEnum>())
            {
                <FluentOption TOption="string" Value="@option.ToString()">@option</FluentOption>
            }
        </FluentSelect>;

    private RenderFragment IntegerField(string label, string? value, Action<string?> setValue, int? min = null)
    {
        var parsed = int.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var current)
            ? current
            : (int?)null;

        return @<FluentNumberField
            TValue="int?"
            Label="@label"
            Value="@parsed"
            ValueChanged="@(newValue => setValue(newValue?.ToString(CultureInfo.InvariantCulture)))"
            Min="@(min?.ToString(CultureInfo.InvariantCulture))"
            Class="field-control" />;
    }

    private RenderFragment NumberField(string label, string? value, Action<string?> setValue, double? min = null)
    {
        var parsed = double.TryParse(value, NumberStyles.Float, CultureInfo.InvariantCulture, out var current)
            ? current
            : (double?)null;

        return @<FluentNumberField
            TValue="double?"
            Label="@label"
            Value="@parsed"
            ValueChanged="@(newValue => setValue(newValue?.ToString(CultureInfo.InvariantCulture)))"
            Min="@(min?.ToString(CultureInfo.InvariantCulture))"
            Step="0.01"
            Class="field-control" />;
    }

    private RenderFragment ColorField(string label, string? value, Action<string?> setValue) => @<FluentTextField
        Label="@label"
        Value="@value"
        ValueChanged="@(newValue => setValue(newValue))"
        TextFieldType="TextFieldType.Color"
        Class="field-control" />;

    private RenderFragment DurationField(string label, string? value, Action<string?> setValue) => @<div class="field duration-field">
        <span>@label</span>
        <div class="duration-grid">
            @IntegerField("Days", GetDurationPart(value, DurationPart.Days), newValue => setValue(SetDurationPart(value, DurationPart.Days, newValue)), 0)
            @IntegerField("Hours", GetDurationPart(value, DurationPart.Hours), newValue => setValue(SetDurationPart(value, DurationPart.Hours, newValue)), 0)
            @IntegerField("Minutes", GetDurationPart(value, DurationPart.Minutes), newValue => setValue(SetDurationPart(value, DurationPart.Minutes, newValue)), 0)
        </div>
    </div>;

    private RenderFragment DateTimeOffsetField(string label, string? value, Action<string?> setValue) => @<div class="field field-wide date-time-field">
        <span>@label</span>
        <div class="date-time-controls">
            <FluentDatePicker
                Label="Date"
                Value="@GetDatePart(value)"
                ValueChanged="@(newValue => setValue(SetDatePart(value, newValue)))"
                Class="field-control" />
            <FluentTimePicker
                Label="Time"
                Value="@GetTimePart(value)"
                ValueChanged="@(newValue => setValue(SetTimePart(value, newValue)))"
                Class="field-control" />
        </div>
    </div>;

    private RenderFragment UnitValueFields(string label, UnitValueForm form) => @<fieldset class="inline-fieldset">
        <legend>@label</legend>
        @NumberField("Value", form.Value, value => form.Value = value, 0)
        @TextField("Unit", form.Unit, value => form.Unit = value)
    </fieldset>;

    private RenderFragment PermissionFields(HashSet<ActionType> permissions) => @<fieldset class="permission-grid">
        <legend>Permissions</legend>
        @foreach (var action in Enum.GetValues<ActionType>())
        {
            @CheckboxField(action.ToString(), permissions.Contains(action), value => TogglePermission(permissions, action, value))
        }
    </fieldset>;

