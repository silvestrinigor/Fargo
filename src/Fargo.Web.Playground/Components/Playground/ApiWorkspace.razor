                        <FluentButton Appearance="Appearance.Accent" Disabled="@isBusy" @onclick="GetUserGroupAsync">Get user group</FluentButton>
                    </div>
                    break;
                case OperationIds.Create:
                    @UserGroupCreateFields()
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Accent" Disabled="@isBusy" @onclick="CreateUserGroupAsync">Create user group</FluentButton>
                    </div>
                    break;
                case OperationIds.Update:
                    <div class="form-grid">
                        @GuidField("User group GUID", userGroupUpdate.Guid, value => userGroupUpdate.Guid = value)
                    </div>
                    @UserGroupUpdateFields()
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Accent" Disabled="@isBusy" @onclick="UpdateUserGroupAsync">Update user group</FluentButton>
                    </div>
                    break;
                case OperationIds.Delete:
                    <div class="form-grid">
                        @GuidField("User group GUID", userGroupDelete.Guid, value => userGroupDelete.Guid = value)
                        @ConfirmField(userGroupDelete.Confirm, value => userGroupDelete.Confirm = value, "I understand this user group will be deleted")
                    </div>
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Outline" Disabled="@(isBusy || !userGroupDelete.Confirm)" @onclick="DeleteUserGroupAsync">Delete user group</FluentButton>
                    </div>
                    break;
            }
        </section>;

    private RenderFragment PartitionsRequestContent() => @<section class="request-form">
            @switch (selectedPartitionOperation)
            {
                case OperationIds.GetMany:
                    @ListQueryFields(partitionListQuery)
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Accent" Disabled="@isBusy" @onclick="GetPartitionsAsync">Get partitions</FluentButton>
                    </div>
                    break;
                case OperationIds.GetByGuid:
                    <div class="form-grid">
                        @GuidField("Partition GUID", partitionGet.Guid, value => partitionGet.Guid = value)
                    </div>
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Accent" Disabled="@isBusy" @onclick="GetPartitionAsync">Get partition</FluentButton>
                    </div>
                    break;
                case OperationIds.Create:
                    <div class="form-grid">
                        @TextField("Name", partitionCreate.Name, value => partitionCreate.Name = value)
                        @TextField("Description", partitionCreate.Description, value => partitionCreate.Description = value)
                        @TextField("Parent partition GUID", partitionCreate.ParentPartitionGuid, value => partitionCreate.ParentPartitionGuid = value)
                    </div>
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Accent" Disabled="@isBusy" @onclick="CreatePartitionAsync">Create partition</FluentButton>
                    </div>
                    break;
                case OperationIds.Update:
                    <div class="form-grid">
                        @GuidField("Partition GUID", partitionUpdate.Guid, value => partitionUpdate.Guid = value)
                        @TextField("Name", partitionUpdate.Name, value => partitionUpdate.Name = value)
                        @TextField("Description", partitionUpdate.Description, value => partitionUpdate.Description = value)
                        @TextField("Parent partition GUID", partitionUpdate.ParentPartitionGuid, value => partitionUpdate.ParentPartitionGuid = value)
                        @OptionalBoolField("Active", partitionUpdate.IncludeIsActive, value => partitionUpdate.IncludeIsActive = value, partitionUpdate.IsActive, value => partitionUpdate.IsActive = value)
                    </div>
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Accent" Disabled="@isBusy" @onclick="UpdatePartitionAsync">Update partition</FluentButton>
                    </div>
                    break;
                case OperationIds.Delete:
                    <div class="form-grid">
                        @GuidField("Partition GUID", partitionDelete.Guid, value => partitionDelete.Guid = value)
                        @ConfirmField(partitionDelete.Confirm, value => partitionDelete.Confirm = value, "I understand this partition will be deleted")
                    </div>
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Outline" Disabled="@(isBusy || !partitionDelete.Confirm)" @onclick="DeletePartitionAsync">Delete partition</FluentButton>
                    </div>
                    break;
            }
        </section>;

    private RenderFragment AccountRequestContent() => @<section class="request-form">
            @switch (selectedAccountOperation)
            {
                case OperationIds.RefreshAuth:
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Accent" Disabled="@isBusy" @onclick="RefreshAuthAsync">Refresh token</FluentButton>
                    </div>
                    break;
                case OperationIds.ChangePassword:
                    <div class="form-grid">
                        @TextField("Current password", accountPassword.CurrentPassword, value => accountPassword.CurrentPassword = value, type: "password")
                        @TextField("New password", accountPassword.NewPassword, value => accountPassword.NewPassword = value, type: "password")
                    </div>
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Accent" Disabled="@isBusy" @onclick="ChangePasswordAsync">Change password</FluentButton>
                    </div>
                    break;
                case OperationIds.Logout:
                    <div class="form-grid">
                        @ConfirmField(accountLogoutConfirmed, value => accountLogoutConfirmed = value, "I understand this will end the current session")
                    </div>
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Outline" Disabled="@(isBusy || !accountLogoutConfirmed)" @onclick="LogoutAsync">Logout</FluentButton>
                    </div>
                    break;
                case OperationIds.ClearSavedAuth:
                    <div class="form-grid">
                        @ConfirmField(accountClearSavedAuthConfirmed, value => accountClearSavedAuthConfirmed = value, "I understand this will clear the saved authentication data")
                    </div>
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Outline" Disabled="@(isBusy || !accountClearSavedAuthConfirmed)" @onclick="ClearSavedAuthAsync">Clear saved auth</FluentButton>
                    </div>
                    break;
            }
        </section>;

    private RenderFragment ResponseContent() => @<section class="response-data">
            @switch (Resource)
            {
                case PlaygroundResource.Articles:
                    @ArticlesResponse()
                    break;
                case PlaygroundResource.Items:
                    @ItemsResponse()
                    break;
                case PlaygroundResource.Users:
                    @UsersResponse()
                    break;
                case PlaygroundResource.UserGroups:
                    @UserGroupsResponse()
                    break;
                case PlaygroundResource.Partitions:
                    @PartitionsResponse()
                    break;
                case PlaygroundResource.Account:
                    @AccountResponse()
                    break;
            }
        </section>;

    private RenderFragment ArticlesResponse() => @<div class="@ResponseLayoutClass(HasArticleGrid, CurrentArticleDetail is not null)">
            @if (HasArticleGrid && CurrentArticleDetail is not null)
            {
                @SplitResponse(ResponseMain(ArticleTable(articleRows)), ArticleDetailsPane(CurrentArticleDetail))
            }
            else if (HasArticleGrid)
            {
                @ResponseMain(ArticleTable(articleRows))
            }
            else if (CurrentArticleDetail is null)
            {
                @FallbackResponse("No article response yet")
            }

            @if (!HasArticleGrid && CurrentArticleDetail is not null)
            {
                @ArticleDetailsPane(CurrentArticleDetail)
            }
        </div>;

    private RenderFragment ItemsResponse() => @<div class="@ResponseLayoutClass(HasItemGrid, CurrentItemDetail is not null)">
            @if (HasItemGrid && CurrentItemDetail is not null)
            {
                @SplitResponse(ResponseMain(ItemTable(itemRows)), ItemDetailsPane(CurrentItemDetail))
            }
            else if (HasItemGrid)
            {
                @ResponseMain(ItemTable(itemRows))
            }
            else if (CurrentItemDetail is null)
            {
                @FallbackResponse("No item response yet")
            }

            @if (!HasItemGrid && CurrentItemDetail is not null)
            {
                @ItemDetailsPane(CurrentItemDetail)
            }
        </div>;

    private RenderFragment UsersResponse() => @<div class="@ResponseLayoutClass(HasUserGrid, CurrentUserDetail is not null)">
            @if (HasUserGrid && CurrentUserDetail is not null)
            {
                @SplitResponse(ResponseMain(UserTable(userRows)), UserDetailsPane(CurrentUserDetail))
            }
            else if (HasUserGrid)
            {
                @ResponseMain(UserTable(userRows))
            }
            else if (CurrentUserDetail is null)
            {
                @FallbackResponse("No user response yet")
            }

            @if (!HasUserGrid && CurrentUserDetail is not null)
            {
                @UserDetailsPane(CurrentUserDetail)
            }
        </div>;

    private RenderFragment UserGroupsResponse() => @<div class="@ResponseLayoutClass(HasUserGroupGrid, CurrentUserGroupDetail is not null)">
            @if (HasUserGroupGrid && CurrentUserGroupDetail is not null)
            {
                @SplitResponse(ResponseMain(UserGroupTable(userGroupRows)), UserGroupDetailsPane(CurrentUserGroupDetail))
            }
            else if (HasUserGroupGrid)
            {
                @ResponseMain(UserGroupTable(userGroupRows))
            }
            else if (CurrentUserGroupDetail is null)
            {
                @FallbackResponse("No user group response yet")
            }

            @if (!HasUserGroupGrid && CurrentUserGroupDetail is not null)
            {
                @UserGroupDetailsPane(CurrentUserGroupDetail)
            }
        </div>;

    private RenderFragment PartitionsResponse() => @<div class="@ResponseLayoutClass(HasPartitionGrid, CurrentPartitionDetail is not null)">
            @if (HasPartitionGrid && CurrentPartitionDetail is not null)
            {
                @SplitResponse(ResponseMain(PartitionTable(partitionRows)), PartitionDetailsPane(CurrentPartitionDetail))
            }
            else if (HasPartitionGrid)
            {
                @ResponseMain(PartitionTable(partitionRows))
            }
            else if (CurrentPartitionDetail is null)
            {
                @FallbackResponse("No partition response yet")
            }

            @if (!HasPartitionGrid && CurrentPartitionDetail is not null)
            {
                @PartitionDetailsPane(CurrentPartitionDetail)
            }
        </div>;

    private RenderFragment AccountResponse() => @<div>
            @if (result?.Payload is AuthDto auth)
            {
                @AuthDetail(auth)
            }
            else if (Session.CurrentAuth is not null)
            {
                @AuthDetail(Session.CurrentAuth)
            }
            else
            {
                @FallbackResponse("No account response yet")
            }
        </div>;

    private RenderFragment PayloadContent(object payload) => @<div>
            @switch (payload)
            {
                case AuthDto auth:
                    @AuthDetail(auth)
                    break;
                case string text:
                    <p class="response-note">@text</p>
                    break;
                case FargoProblemDetailsDto:
                    @EmptyResponse("Request failed")
                    break;
                default:
                    @EmptyResponse("No structured view for this response")
                    break;
            }
        </div>;

    private RenderFragment FallbackResponse(string emptyMessage) => @<div>
            @if (result?.Payload is not null)
            {
                @PayloadContent(result.Payload)
            }
            else if (result is not null)
            {
                @EmptyResponse("No response body")
            }
            else
            {
                @EmptyResponse(emptyMessage)
            }
        </div>;

