                    </div>
                    break;
                case OperationIds.Create:
                    @UserCreateFields()
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Accent" Disabled="@isBusy" @onclick="CreateUserAsync">Create user</FluentButton>
                    </div>
                    break;
                case OperationIds.Update:
                    <div class="form-grid">
                        @GuidField("User GUID", userUpdate.Guid, value => userUpdate.Guid = value)
                    </div>
