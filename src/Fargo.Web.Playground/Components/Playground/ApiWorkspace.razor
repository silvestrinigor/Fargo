    private async Task RunAsync(
        string operationId,
        string successTitle,
        Func<IFargoHttpClient, Task<object?>> operation)
    {
        isBusy = true;
        result = null;
        SetSubmittedOperation(operationId);

        try
        {
            var client = await ClientFactory.CreateAsync();
            if (client is null)
            {
                NavigationManager.NavigateTo("/", forceLoad: true);
                return;
            }

            var payload = await operation(client);
            result = OperationResult.Success(successTitle, payload is string message ? message : "Operation completed.", payload);
            isActionDialogHidden = true;
            activeOperationId = null;
        }
        catch (FargoHttpApiException exception) when (exception.StatusCode == HttpStatusCode.Unauthorized)
        {
            await Session.ClearAsync();
            NavigationManager.NavigateTo("/", forceLoad: true);
        }
        catch (FargoHttpApiException exception)
        {
            result = OperationResult.Failure(
                "API request failed",
                exception.ProblemDetails?.Detail ?? exception.Message,
                exception.ProblemDetails is null ? exception.RawBody : exception.ProblemDetails);
        }
        catch (Exception exception)
        {
            result = OperationResult.Failure("Operation failed", exception.Message, null);
        }
        finally
        {
            isBusy = false;
        }
    }

    private ArticleCreateRequest BuildArticleCreateRequest()
    {
        var maxMass = BuildUnitValue(articleCreate.ContainerMaxMass, "Container max mass");

        return new ArticleCreateRequest(
            RequiredText(articleCreate.Name, "Name"),
            articleCreate.ArticleType,
            Clean(articleCreate.Description),
            ParseNullableTimeSpan(articleCreate.ShelfLife, "Shelf life"),
            Clean(articleCreate.Color),
            BuildArticleMetrics(articleCreate.Metrics),
            BuildArticleBarcodes(articleCreate.Barcodes),
            ParseGuidList(articleCreate.PartitionsText, "Partitions"),
            OptionalBool(articleCreate.IncludeIsActive, articleCreate.IsActive),
            articleCreate.ArticleType == ArticleType.Variation
                ? new ArticleCreateVariationRequest(RequiredGuid(articleCreate.FromArticleGuid, "From article GUID"))
                : null,
            articleCreate.ArticleType == ArticleType.Pack
                ? new ArticleCreatePackRequest(
                    RequiredGuid(articleCreate.FromArticleGuid, "From article GUID"),
                    RequiredDouble(articleCreate.Quantity, "Quantity"))
                : null,
            articleCreate.ArticleType == ArticleType.Kit
                ? new ArticleCreateKitRequest(ParseKitPacks(articleCreate.KitPacksText))
                : null,
            articleCreate.ArticleType == ArticleType.Container && maxMass is not null
                ? new ArticleCreateContainerRequest(maxMass)
                : null);
    }

    private ArticlePatchRequest BuildArticlePatchRequest()
    {
        var request = new ArticlePatchRequest
        {
            Name = OptionalText(articlePatch.IncludeName, articlePatch.Name),
            Description = OptionalText(articlePatch.IncludeDescription, articlePatch.Description),
            Metrics = articlePatch.IncludeMetrics ? BuildArticleMetrics(articlePatch.Metrics) : null,
            Barcodes = articlePatch.IncludeBarcodes ? BuildArticleBarcodes(articlePatch.Barcodes) : null,
            Partitions = articlePatch.IncludePartitions ? ParseGuidList(articlePatch.PartitionsText, "Partitions") : null,
            IsActive = OptionalBool(articlePatch.IncludeIsActive, articlePatch.IsActive)
        };

        request = articlePatch.ShelfLifeMode switch
        {
            ShelfLifePatchMode.Set => request with
            {
                ShelfLife = OptionalField<TimeSpan>.FromValue(RequiredTimeSpan(articlePatch.ShelfLife, "Shelf life"))
            },
            ShelfLifePatchMode.Clear => request with
            {
                ShelfLife = OptionalField<TimeSpan>.FromValue(null)
            },
            _ => request
        };

        return request;
    }

    private static ArticleMetricsDto? BuildArticleMetrics(ArticleMetricsForm form)
    {
        var metrics = new ArticleMetricsDto(
            BuildUnitValue(form.Mass, "Mass"),
            BuildUnitValue(form.LengthX, "Length X"),
            BuildUnitValue(form.LengthY, "Length Y"),
            BuildUnitValue(form.LengthZ, "Length Z"));

        return metrics.Mass is null &&
               metrics.LengthX is null &&
               metrics.LengthY is null &&
               metrics.LengthZ is null
            ? null
            : metrics;
    }

    private static ArticleBarcodesDto? BuildArticleBarcodes(ArticleBarcodesForm form)
    {
        var barcodes = new ArticleBarcodesDto(
            Clean(form.Ean13),
            Clean(form.Ean8),
            Clean(form.UpcA),
            Clean(form.UpcE),
            Clean(form.Code128),
            Clean(form.Code39),
            Clean(form.Itf14),
            Clean(form.Gs1128),
            Clean(form.QrCode),
            Clean(form.DataMatrix));

        return barcodes.Ean13 is null &&
               barcodes.Ean8 is null &&
               barcodes.UpcA is null &&
               barcodes.UpcE is null &&
               barcodes.Code128 is null &&
               barcodes.Code39 is null &&
               barcodes.Itf14 is null &&
               barcodes.Gs1128 is null &&
               barcodes.QrCode is null &&
               barcodes.DataMatrix is null
            ? null
            : barcodes;
    }

    private static IReadOnlyCollection<ArticleCreateKitPackRequest> ParseKitPacks(string? value)
    {
        var rows = SplitLines(value);
        if (rows.Count == 0)
        {
            throw new InvalidOperationException("Kit packs require at least one 'articleGuid,quantity' line.");
        }

        return rows.Select((row, index) =>
        {
            var parts = row.Split(',', StringSplitOptions.TrimEntries);
            if (parts.Length != 2)
            {
                throw new InvalidOperationException($"Kit pack line {index + 1} must be 'articleGuid,quantity'.");
            }

            return new ArticleCreateKitPackRequest(
                RequiredGuid(parts[0], $"Kit pack line {index + 1} article GUID"),
                RequiredDouble(parts[1], $"Kit pack line {index + 1} quantity"));
        }).ToArray();
    }

    private static UnitValueDto? BuildUnitValue(UnitValueForm form, string label)
    {
        if (string.IsNullOrWhiteSpace(form.Value) && string.IsNullOrWhiteSpace(form.Unit))
        {
            return null;
        }

        if (!double.TryParse(form.Value, NumberStyles.Float, CultureInfo.InvariantCulture, out var parsedValue))
        {
            throw new InvalidOperationException($"{label} value is not a valid number.");
        }

        return new UnitValueDto(parsedValue, RequiredText(form.Unit, $"{label} unit"));
    }

