                        <FluentButton Appearance="Appearance.Accent" Disabled="@isBusy" @onclick="UpdateUserAsync">Update user</FluentButton>
                    </div>
                    break;
                case OperationIds.Delete:
                    <div class="form-grid">
                        @GuidField("User GUID", userDelete.Guid, value => userDelete.Guid = value)
