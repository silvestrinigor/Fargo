@using System.Globalization
@using System.Net
@using System.Text.Json
@using System.Text.Json.Serialization
@inject PlaygroundApiClientFactory ClientFactory
@inject PlaygroundAuthSession Session
@inject NavigationManager NavigationManager

<section class="api-workspace">
    @ResourceWorkspace()
    @ActionDialog()
</section>

@code {
    private static readonly JsonSerializerOptions JsonOptions = CreateDisplayJsonOptions();

    [Parameter]
    public PlaygroundResource Resource { get; set; } = PlaygroundResource.Articles;

    private bool isBusy;
    private OperationResult? result;
    private string? selectedArticleOperation;
    private string? selectedItemOperation;
    private string? selectedUserOperation;
    private string? selectedUserGroupOperation;
    private string? selectedPartitionOperation;
    private string? selectedAccountOperation;
    private string? submittedArticleOperation;
    private string? submittedItemOperation;
    private string? submittedUserOperation;
    private string? submittedUserGroupOperation;
    private string? submittedPartitionOperation;
    private string? submittedAccountOperation;
    private bool isActionDialogHidden = true;
    private string? activeOperationId;
    private bool accountLogoutConfirmed;
    private bool accountClearSavedAuthConfirmed;

    private static readonly OperationOption[] ArticleOperationChoices =
    [
        new(OperationIds.GetMany, "Get many"),
        new(OperationIds.GetByGuid, "Get by GUID"),
        new(OperationIds.GetByBarcode, "Get by barcode"),
        new(OperationIds.Create, "Create"),
        new(OperationIds.Patch, "Patch"),
        new(OperationIds.Delete, "Delete")
    ];

    private static readonly OperationOption[] CrudOperationChoices =
    [
        new(OperationIds.GetMany, "Get many"),
        new(OperationIds.GetByGuid, "Get by GUID"),
        new(OperationIds.Create, "Create"),
        new(OperationIds.Update, "Update"),
        new(OperationIds.Delete, "Delete")
    ];

    private static readonly OperationOption[] AccountOperationChoices =
    [
        new(OperationIds.RefreshAuth, "Refresh token"),
        new(OperationIds.ChangePassword, "Change password"),
        new(OperationIds.Logout, "Logout"),
        new(OperationIds.ClearSavedAuth, "Clear saved auth")
    ];

    private readonly ListQueryForm articleListQuery = new();
    private readonly ListQueryForm itemListQuery = new();
    private readonly ListQueryForm userListQuery = new();
    private readonly ListQueryForm userGroupListQuery = new();
    private readonly ListQueryForm partitionListQuery = new();

    private readonly GuidForm articleGet = new();
    private readonly ArticleBarcodeForm articleBarcode = new();
    private readonly ArticleCreateForm articleCreate = new();
    private readonly ArticlePatchForm articlePatch = new();
    private readonly ConfirmGuidForm articleDelete = new();
    private IReadOnlyCollection<ArticleDto> articleRows = [];
    private ArticleDto? selectedArticle;

    private readonly GuidForm itemGet = new();
    private readonly ItemCreateForm itemCreate = new();
    private readonly ItemUpdateForm itemUpdate = new();
    private readonly ConfirmGuidForm itemDelete = new();
    private IReadOnlyCollection<ItemDto> itemRows = [];
    private ItemDto? selectedItem;

    private readonly GuidForm userGet = new();
    private readonly UserCreateForm userCreate = new();
    private readonly UserUpdateForm userUpdate = new();
    private readonly ConfirmGuidForm userDelete = new();
    private IReadOnlyCollection<UserDto> userRows = [];
    private UserDto? selectedUser;

    private readonly GuidForm userGroupGet = new();
    private readonly UserGroupCreateForm userGroupCreate = new();
    private readonly UserGroupUpdateForm userGroupUpdate = new();
    private readonly ConfirmGuidForm userGroupDelete = new();
    private IReadOnlyCollection<UserGroupDto> userGroupRows = [];
    private UserGroupDto? selectedUserGroup;

    private readonly GuidForm partitionGet = new();
    private readonly PartitionCreateForm partitionCreate = new();
    private readonly PartitionUpdateForm partitionUpdate = new();
    private readonly ConfirmGuidForm partitionDelete = new();
    private IReadOnlyCollection<PartitionDto> partitionRows = [];
    private PartitionDto? selectedPartition;

    private readonly PasswordForm accountPassword = new();

    private RenderFragment ResourceWorkspace() => @<section class="resource-panel" data-testid="@ResourceTestId()">
            <div class="workspace-actions" role="toolbar" aria-label="Operations">
                @foreach (var operation in CurrentOperationChoices())
                {
                    <FluentButton
                        Appearance="@(operation.Id == SubmittedOperation ? Appearance.Accent : Appearance.Outline)"
                        Disabled="@isBusy"
                        @onclick="() => OpenActionDialog(operation.Id)">
                        @operation.Label
                    </FluentButton>
                }
            </div>
            @OperationResultContent()
            <section class="workspace-data">
                @ResponseContent()
            </section>
        </section>;

    private RenderFragment ActionDialog() => @<FluentDialog
            Class="action-dialog"
            Hidden="@isActionDialogHidden"
            HiddenChanged="@(hidden => OnActionDialogHiddenChanged(hidden))"
            Modal="true"
            TrapFocus="true"
            PreventScroll="true"
            AriaLabel="@ActiveOperationLabel">
            <FluentDialogHeader ShowDismiss="true">
                @ActiveOperationLabel
            </FluentDialogHeader>
            <FluentDialogBody Class="action-dialog-body">
                @RequestContent()
            </FluentDialogBody>
            <FluentDialogFooter Visible="true">
                <FluentButton Appearance="Appearance.Outline" Disabled="@isBusy" @onclick="CloseActionDialog">Close</FluentButton>
            </FluentDialogFooter>
        </FluentDialog>;

    private string? SubmittedOperation => Resource switch
    {
        PlaygroundResource.Articles => submittedArticleOperation,
        PlaygroundResource.Items => submittedItemOperation,
        PlaygroundResource.Users => submittedUserOperation,
        PlaygroundResource.UserGroups => submittedUserGroupOperation,
        PlaygroundResource.Partitions => submittedPartitionOperation,
        PlaygroundResource.Account => submittedAccountOperation,
        _ => null
    };

    private string ActiveOperationLabel
        => activeOperationId is null
            ? "Operation"
            : CurrentOperationChoices().FirstOrDefault(operation => operation.Id == activeOperationId)?.Label ?? "Operation";

    private IReadOnlyCollection<OperationOption> CurrentOperationChoices() => Resource switch
    {
        PlaygroundResource.Articles => ArticleOperationChoices,
        PlaygroundResource.Account => AccountOperationChoices,
        _ => CrudOperationChoices
    };

    private string ResourceTestId() => Resource switch
    {
        PlaygroundResource.Articles => "playground-articles",
        PlaygroundResource.Items => "playground-items",
        PlaygroundResource.Users => "playground-users",
        PlaygroundResource.UserGroups => "playground-user-groups",
        PlaygroundResource.Partitions => "playground-partitions",
        PlaygroundResource.Account => "playground-account",
        _ => "playground-resource"
    };

    private void OpenActionDialog(string operationId)
    {
        SetCurrentOperation(operationId);
        activeOperationId = operationId;
        isActionDialogHidden = false;
    }

    private void CloseActionDialog()
    {
        if (isBusy)
        {
            return;
        }

        isActionDialogHidden = true;
    }

    private void OnActionDialogHiddenChanged(bool hidden)
    {
        isActionDialogHidden = hidden;
    }

    private void SetCurrentOperation(string operationId)
    {
        switch (Resource)
        {
            case PlaygroundResource.Articles:
                selectedArticleOperation = operationId;
                break;
            case PlaygroundResource.Items:
                selectedItemOperation = operationId;
                break;
            case PlaygroundResource.Users:
                selectedUserOperation = operationId;
                break;
            case PlaygroundResource.UserGroups:
                selectedUserGroupOperation = operationId;
                break;
            case PlaygroundResource.Partitions:
                selectedPartitionOperation = operationId;
                break;
            case PlaygroundResource.Account:
                selectedAccountOperation = operationId;
                accountLogoutConfirmed = false;
                accountClearSavedAuthConfirmed = false;
                break;
        }
    }

    private void SetSubmittedOperation(string operationId)
    {
        switch (Resource)
        {
            case PlaygroundResource.Articles:
                submittedArticleOperation = operationId;
                break;
            case PlaygroundResource.Items:
                submittedItemOperation = operationId;
                break;
            case PlaygroundResource.Users:
                submittedUserOperation = operationId;
                break;
            case PlaygroundResource.UserGroups:
                submittedUserGroupOperation = operationId;
                break;
            case PlaygroundResource.Partitions:
                submittedPartitionOperation = operationId;
                break;
            case PlaygroundResource.Account:
                submittedAccountOperation = operationId;
                break;
        }
    }

    private RenderFragment RequestContent() => Resource switch
    {
        PlaygroundResource.Articles => ArticlesRequestContent(),
        PlaygroundResource.Items => ItemsRequestContent(),
        PlaygroundResource.Users => UsersRequestContent(),
        PlaygroundResource.UserGroups => UserGroupsRequestContent(),
        PlaygroundResource.Partitions => PartitionsRequestContent(),
        PlaygroundResource.Account => AccountRequestContent(),
        _ => EmptyResponse("No action available")
    };

    private RenderFragment OperationResultContent() => @<section class="@($"operation-result {(result?.IsSuccess == true ? "success" : result is null ? "idle" : "error")}")" data-testid="playground-operation-result">
            @if (result is null)
            {
                <FluentMessageBar Intent="MessageIntent.Info">
                    <strong>Ready</strong>
                    <span>No request has been sent yet.</span>
                </FluentMessageBar>
            }
            else
            {
                <FluentMessageBar Intent="@(result.IsSuccess ? MessageIntent.Success : MessageIntent.Error)">
                    <strong>@result.Title</strong>
                    <span>@result.Message</span>
                </FluentMessageBar>
                @if (!result.IsSuccess && result.Payload is FargoProblemDetailsDto problem)
                {
                    <div class="detail-grid result-detail">
                        @DetailValue("Status", problem.Status.ToString(CultureInfo.InvariantCulture))
                        @DetailValue("Title", problem.Title)
                        @DetailValue("Detail", problem.Detail)
                        @DetailValue("Type", problem.Type)
                        @DetailValue("Trace", problem.TraceId)
                    </div>
                }
            }
        </section>;

    private RenderFragment ArticlesRequestContent() => @<section class="request-form">
            @switch (selectedArticleOperation)
            {
                case OperationIds.GetMany:
                    @ListQueryFields(articleListQuery)
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Accent" Disabled="@isBusy" @onclick="GetArticlesAsync">Get articles</FluentButton>
                    </div>
                    break;
                case OperationIds.GetByGuid:
                    <div class="form-grid">
                        @GuidField("Article GUID", articleGet.Guid, value => articleGet.Guid = value)
                    </div>
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Accent" Disabled="@isBusy" @onclick="GetArticleAsync">Get article</FluentButton>
                    </div>
                    break;
                case OperationIds.GetByBarcode:
                    <div class="form-grid">
                        @TextField("Barcode", articleBarcode.Code, value => articleBarcode.Code = value)
                        @EnumField("Format", articleBarcode.Format, value => articleBarcode.Format = value)
                    </div>
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Accent" Disabled="@isBusy" @onclick="GetArticleByBarcodeAsync">Get by barcode</FluentButton>
                    </div>
                    break;
                case OperationIds.Create:
                    @ArticleCreateFields()
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Accent" Disabled="@isBusy" @onclick="CreateArticleAsync">Create article</FluentButton>
                    </div>
                    break;
                case OperationIds.Patch:
                    <div class="form-grid">
                        @GuidField("Article GUID", articlePatch.Guid, value => articlePatch.Guid = value)
                    </div>
                    @ArticlePatchFields()
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Accent" Disabled="@isBusy" @onclick="PatchArticleAsync">Patch article</FluentButton>
                    </div>
                    break;
                case OperationIds.Delete:
                    <div class="form-grid">
                        @GuidField("Article GUID", articleDelete.Guid, value => articleDelete.Guid = value)
                        @ConfirmField(articleDelete.Confirm, value => articleDelete.Confirm = value, "I understand this article will be deleted")
                    </div>
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Outline" Disabled="@(isBusy || !articleDelete.Confirm)" @onclick="DeleteArticleAsync">Delete article</FluentButton>
                    </div>
                    break;
            }
        </section>;

    private RenderFragment ItemsRequestContent() => @<section class="request-form">
            @switch (selectedItemOperation)
            {
                case OperationIds.GetMany:
                    @ListQueryFields(itemListQuery)
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Accent" Disabled="@isBusy" @onclick="GetItemsAsync">Get items</FluentButton>
                    </div>
                    break;
                case OperationIds.GetByGuid:
                    <div class="form-grid">
                        @GuidField("Item GUID", itemGet.Guid, value => itemGet.Guid = value)
                    </div>
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Accent" Disabled="@isBusy" @onclick="GetItemAsync">Get item</FluentButton>
                    </div>
                    break;
                case OperationIds.Create:
                    <div class="form-grid">
                        @GuidField("Article GUID", itemCreate.ArticleGuid, value => itemCreate.ArticleGuid = value)
                        @DateTimeOffsetField("Production date", itemCreate.ProductionDate, value => itemCreate.ProductionDate = value)
                        @TextAreaField("Partitions", itemCreate.PartitionsText, value => itemCreate.PartitionsText = value)
                        @OptionalBoolField("Active", itemCreate.IncludeIsActive, value => itemCreate.IncludeIsActive = value, itemCreate.IsActive, value => itemCreate.IsActive = value)
                    </div>
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Accent" Disabled="@isBusy" @onclick="CreateItemAsync">Create item</FluentButton>
                    </div>
                    break;
                case OperationIds.Update:
                    <div class="form-grid">
                        @GuidField("Item GUID", itemUpdate.Guid, value => itemUpdate.Guid = value)
                        @TextAreaField("Partitions", itemUpdate.PartitionsText, value => itemUpdate.PartitionsText = value)
                        @TextField("Parent container GUID", itemUpdate.ParentContainerGuid, value => itemUpdate.ParentContainerGuid = value)
                        @OptionalBoolField("Active", itemUpdate.IncludeIsActive, value => itemUpdate.IncludeIsActive = value, itemUpdate.IsActive, value => itemUpdate.IsActive = value)
                    </div>
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Accent" Disabled="@isBusy" @onclick="UpdateItemAsync">Update item</FluentButton>
                    </div>
                    break;
                case OperationIds.Delete:
                    <div class="form-grid">
                        @GuidField("Item GUID", itemDelete.Guid, value => itemDelete.Guid = value)
                        @ConfirmField(itemDelete.Confirm, value => itemDelete.Confirm = value, "I understand this item will be deleted")
                    </div>
                    <div class="request-actions">
                        <FluentButton Appearance="Appearance.Outline" Disabled="@(isBusy || !itemDelete.Confirm)" @onclick="DeleteItemAsync">Delete item</FluentButton>
                    </div>
                    break;
            }
        </section>;

