@inherits LayoutComponentBase

<FluentLayout>
    <FluentHeader>
        <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" VerticalAlignment="VerticalAlignment.Center" Width="100%">
            <span>Fargo Playground</span>
            <FluentBadge Appearance="Appearance.Neutral">Development</FluentBadge>
        </FluentStack>
    </FluentHeader>
    <FluentBodyContent Class="body-content">
        <main class="content">
            @Body
        </main>
    </FluentBodyContent>
</FluentLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>
