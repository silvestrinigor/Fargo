@page "/login"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.WebUtilities
@using System.Text.Json
@inject IFargoIdentityClient IdentityClient
@inject IdentitySession Session
@inject NavigationManager NavigationManager
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Environment

<PageTitle>Login</PageTitle>

<h1>Login</h1>

<EditForm Model=form OnValidSubmit=LoginAsync>
    <DataAnnotationsValidator />

    <FluentStack Orientation="Orientation.Vertical" Width="320px">
        <FluentTextField
            @bind-Value=form.Nameid
            Disabled=isSubmitting
            TextFieldType="TextFieldType.Text"
            Required>
            Nameid
        </FluentTextField>

        <FluentTextField
            @bind-Value=form.Password
            Disabled=isSubmitting
            TextFieldType="TextFieldType.Password"
            Required>
            Password
        </FluentTextField>

        <FluentButton
            Appearance="Appearance.Accent"
            Disabled=isSubmitting
            Type="ButtonType.Submit">
            @(isSubmitting ? "Logging in" : "Login")
        </FluentButton>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <FluentMessageBar Intent=messageIntent>
                @message
            </FluentMessageBar>
        }
    </FluentStack>
</EditForm>

@if (Session.IsAuthenticated)
{
    <p>Authenticated until @Session.CurrentAuth!.ExpiresAt.LocalDateTime.</p>
}

@code {
    private static readonly JsonSerializerOptions JsonOptions = FargoHttpJsonSerializerOptions.Create();

    private readonly LoginForm form = new();
    private bool isSubmitting;
    private string? message;
    private MessageIntent messageIntent = MessageIntent.Info;

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "state")]
    public string? State { get; set; }

    private async Task LoginAsync()
    {
        isSubmitting = true;
        message = null;
        Session.Clear();

        try
        {
            var auth = await IdentityClient.LoginAsync(
                new LoginRequest(form.Nameid, form.Password));

            Session.Set(auth);
            form.Password = string.Empty;

            if (TryBuildPlaygroundReturnUri(auth, out var returnUri))
            {
                NavigationManager.NavigateTo(returnUri, forceLoad: true);
                return;
            }

            messageIntent = MessageIntent.Success;
            message = "Logged in.";
        }
        catch (FargoHttpApiException exception)
        {
            messageIntent = MessageIntent.Error;
            message = exception.ProblemDetails?.Detail
                ?? exception.Message;
        }
        catch (Exception exception) when (exception is HttpRequestException or TaskCanceledException)
        {
            messageIntent = MessageIntent.Error;
            message = "The Fargo HTTP API is unavailable.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private bool TryBuildPlaygroundReturnUri(
        AuthDto auth,
        out string returnUri)
    {
        returnUri = string.Empty;

        if (!Environment.IsDevelopment() ||
            string.IsNullOrWhiteSpace(ReturnUrl) ||
            string.IsNullOrWhiteSpace(State) ||
            !Uri.TryCreate(ReturnUrl, UriKind.Absolute, out var callbackUri) ||
            !IsAllowedPlaygroundReturn(callbackUri))
        {
            return false;
        }

        var payload = WebEncoders.Base64UrlEncode(
            JsonSerializer.SerializeToUtf8Bytes(auth, JsonOptions));

        returnUri = QueryHelpers.AddQueryString(
            callbackUri.ToString(),
            new Dictionary<string, string?>
            {
                ["auth"] = payload,
                ["state"] = State
            });

        return true;
    }

    private bool IsAllowedPlaygroundReturn(Uri callbackUri)
    {
        foreach (var allowedOrigin in GetAllowedReturnOrigins())
        {
            if (!Uri.TryCreate(allowedOrigin, UriKind.Absolute, out var allowedUri))
            {
                continue;
            }

            if (string.Equals(callbackUri.Scheme, allowedUri.Scheme, StringComparison.OrdinalIgnoreCase) &&
                string.Equals(callbackUri.Host, allowedUri.Host, StringComparison.OrdinalIgnoreCase) &&
                callbackUri.Port == allowedUri.Port)
            {
                return true;
            }
        }

        return false;
    }

    private IEnumerable<string> GetAllowedReturnOrigins()
    {
        foreach (var origin in Configuration.GetSection("FargoWebPlayground:AllowedReturnOrigins").GetChildren())
        {
            if (!string.IsNullOrWhiteSpace(origin.Value))
            {
                yield return origin.Value;
            }
        }

        var configuredOrigin = Configuration["FargoWebPlayground:AllowedReturnOrigin"];
        if (!string.IsNullOrWhiteSpace(configuredOrigin))
        {
            yield return configuredOrigin;
        }
    }

    private sealed class LoginForm
    {
        public string Nameid { get; set; } = string.Empty;

        public string Password { get; set; } = string.Empty;
    }
}
