@using Fargo.Sdk
@using Fargo.Web.Components.Shared

@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Navigation
@inject IEngine Engine
@inject FargoSession FargoSession

<SessionBootstrapper />

@if (!FargoSession.IsReady)
{
    <div class="splash-screen">
        <h1>Fargo</h1>
        <p>Loading workspace...</p>
    </div>
}
else if (!FargoSession.IsAuthenticated)
{
    <div class="splash-screen">
        <h1>Fargo</h1>
        <p>Redirecting to login...</p>
    </div>
}
else
{
    <div class="app-shell">
        <header class="app-header">
            <div class="app-header-side app-header-branding">
                <div class="app-brand">Fargo</div>
                <div class="app-subtitle">Tree-first administration workspace</div>
            </div>

            <nav class="app-nav" aria-label="Primary">
                <a class="@(IsPartitionsActive() ? "nav-link active" : "nav-link")" href="/partitions">Partitions</a>
                <a class="@(IsActive("/users") ? "nav-link active" : "nav-link")" href="/users">Users</a>
                <a class="@(IsActive("/articles") ? "nav-link active" : "nav-link")" href="/articles">Articles</a>
                <a class="@(IsActive("/entities") ? "nav-link active" : "nav-link")" href="/entities">Entities</a>
            </nav>

            <div class="app-header-side app-header-actions">
                <button type="button" class="ghost-button" @onclick="LogoutAsync">Sign out</button>
            </div>
        </header>

        <main class="app-main">
            @Body
        </main>
    </div>
}

@code {
    protected override void OnInitialized()
    {
        FargoSession.Changed += HandleSessionChanged;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (FargoSession.IsReady && !FargoSession.IsAuthenticated && !Navigation.Uri.Contains("/login", StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo("/login", replace: true);
        }
    }

    private async Task LogoutAsync()
    {
        await Engine.LogOutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private bool IsPartitionsActive() => IsActive("/partitions") || IsActive("/workspace");

    private bool IsActive(string path)
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
        return relative.StartsWith(path.TrimStart('/'), StringComparison.OrdinalIgnoreCase);
    }

    private void HandleSessionChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        FargoSession.Changed -= HandleSessionChanged;
    }
}
