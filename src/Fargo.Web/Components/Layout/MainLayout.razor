@using Fargo.Web.Components.Shared

@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Navigation
@inject IClientSessionStore SessionStore
@inject ClientSessionAccessor SessionAccessor

<SessionBootstrapper />

@if (!SessionAccessor.IsReady)
{
    <div class="splash-screen">
        <h1>Fargo</h1>
        <p>Loading workspace...</p>
    </div>
}
else if (!SessionAccessor.IsAuthenticated)
{
    <div class="splash-screen">
        <h1>Fargo</h1>
        <p>Redirecting to login...</p>
    </div>
}
else
{
    var sidebarSection = GetSidebarSection();

    <div class="app-shell">
        <header class="app-header">
            <div>
                <div class="app-brand">Fargo</div>
                <div class="app-subtitle">Tree-first administration workspace</div>
            </div>

            <nav class="app-nav">
                <a class="@(IsPartitionsActive() ? "nav-link active" : "nav-link")" href="/partitions">Partitions</a>
                <a class="@(IsActive("/users") ? "nav-link active" : "nav-link")" href="/users">Users</a>
                <a class="@(IsActive("/articles") ? "nav-link active" : "nav-link")" href="/articles">Articles</a>
                <a class="@(IsActive("/entities") ? "nav-link active" : "nav-link")" href="/entities">Entities</a>
            </nav>

            <button type="button" class="ghost-button" @onclick="LogoutAsync">Sign out</button>
        </header>

        <div class="app-body">
            <aside class="app-sidebar">
                <div class="sidebar-header">
                    <h2>@sidebarSection.Title</h2>
                    <p>@sidebarSection.Description</p>
                </div>

                @switch (sidebarSection.Kind)
                {
                    case SidebarSectionKind.Users:
                        <UserGroupTree />
                        break;
                    case SidebarSectionKind.Articles:
                        <ArticleTree />
                        break;
                    default:
                        <PartitionTree />
                        break;
                }
            </aside>

            <main class="app-content">
                @Body
            </main>
        </div>
    </div>
}

@code {
    protected override void OnInitialized()
    {
        SessionAccessor.Changed += HandleSessionChanged;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (SessionAccessor.IsReady && !SessionAccessor.IsAuthenticated && !Navigation.Uri.Contains("/login",
StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo("/login", replace: true);
        }
    }

    private async Task LogoutAsync()
    {
        await SessionStore.ClearAsync();
        SessionAccessor.Clear();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private bool IsPartitionsActive() => IsActive("/partitions") || IsActive("/workspace");

    private bool IsActive(string path)
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
        return relative.StartsWith(path.TrimStart('/'), StringComparison.OrdinalIgnoreCase);
    }

    private SidebarSection GetSidebarSection()
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri);

        if (relative.StartsWith("users", StringComparison.OrdinalIgnoreCase))
        {
            return new SidebarSection(
                "Users",
                "Browse user groups and open the selected group in the users workspace.",
                SidebarSectionKind.Users);
        }

        if (relative.StartsWith("articles", StringComparison.OrdinalIgnoreCase))
        {
            return new SidebarSection(
                "Articles",
                "Browse the article tree and inspect the selected article on the right.",
                SidebarSectionKind.Articles);
        }

        return new SidebarSection(
            "Partitions",
            "Browse partitions and manage the selected partition on the right.",
            SidebarSectionKind.Partitions);
    }

    private void HandleSessionChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        SessionAccessor.Changed -= HandleSessionChanged;
    }

    private sealed record SidebarSection(
        string Title,
        string Description,
        SidebarSectionKind Kind);

    private enum SidebarSectionKind
    {
        Partitions,
        Users,
        Articles
    }
}