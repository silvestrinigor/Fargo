@page "/entities"
@page "/entities/{Section}"
@page "/entities/{Section}/{EntityGuid:guid}"
@inject IEngine Engine
@inject NavigationManager Navigation

<PageTitle>Fargo Entities</PageTitle>

@if (sectionPickerOpen)
{
    <div class="picker-backdrop" @onclick="ClosePicker"></div>
}

<div class="workspace-surface entities-surface">
    <aside class="workspace-explorer">
        <div class="section-picker">
            <button type="button" class="section-picker-trigger" @onclick="TogglePicker">
                <span>@ActiveSectionLabel</span>
                <span class="picker-arrow @(sectionPickerOpen ? "open" : null)">▾</span>
            </button>
            @if (sectionPickerOpen)
            {
                <div class="section-picker-menu">
                    <a href="/entities/partitions"
                       class="section-picker-item @(ActiveSection == "partitions" ? "active" : null)">Partitions</a>
                    <a href="/entities/articles"
                       class="section-picker-item @(ActiveSection == "articles" ? "active" : null)">Articles</a>
                    <a href="/entities/users"
                       class="section-picker-item @(ActiveSection == "users" ? "active" : null)">Users</a>
                    <a href="/entities/items"
                       class="section-picker-item @(ActiveSection == "items" ? "active" : null)">Items</a>
                </div>
            }
        </div>

        <div class="workspace-pane-body">
            @if (ActiveSection == "articles")
            {
                <ArticleTree />
            }
            else if (ActiveSection == "users")
            {
                <UserGroupTree />
            }
            else if (ActiveSection == "items")
            {
                <ItemTree />
            }
            else
            {
                <PartitionTree />
            }
        </div>

        <div class="workspace-pane-footer">
            <button type="button" class="ghost-button" @onclick="OpenCreateDialog">New @ActiveSectionSingularLabel</button>
        </div>
    </aside>

    <section class="workspace-detail">
        <div class="workspace-detail-body">

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="error-banner">@errorMessage</div>
            }

            @if (ActiveSection == "users")
            {
                @if (!EntityGuid.HasValue)
                {
                    <div class="detail-empty">
                        <p class="muted-text">Select a user to view and edit their details.</p>
                    </div>
                }
                else if (userIsLoading)
                {
                    <p class="muted-text">Loading...</p>
                }
                else if (selectedUser is null)
                {
                    <p class="muted-text">User could not be loaded.</p>
                }
                else
                {
                    <div class="workspace-stack">
                        <section class="workspace-panel">
                            <dl class="detail-list detail-list--inline">
                                <div>
                                    <dt>Status</dt>
                                    <dd>@(selectedUser.IsActive ? "Active" : "Inactive")</dd>
                                </div>
                                <div>
                                    <dt>Partitions</dt>
                                    <dd>@selectedUser.PartitionAccesses.Count</dd>
                                </div>
                            </dl>
                            <EditForm Model="userEditModel" OnValidSubmit="SaveUserAsync" class="editor-form">
                                <DataAnnotationsValidator />
                                <label>
                                    <span>NameId</span>
                                    <InputText @bind-Value="userEditModel.Nameid" class="text-field" />
                                    <ValidationMessage For="() => userEditModel.Nameid" />
                                </label>
                                <div class="editor-form two-columns">
                                    <label>
                                        <span>First name</span>
                                        <InputText @bind-Value="userEditModel.FirstName" class="text-field" />
                                    </label>
                                    <label>
                                        <span>Last name</span>
                                        <InputText @bind-Value="userEditModel.LastName" class="text-field" />
                                    </label>
                                </div>
                                <label>
                                    <span>Description</span>
                                    <InputTextArea @bind-Value="userEditModel.Description" class="text-area" />
                                </label>
                                <div class="dialog-actions">
                                    <button type="submit" class="primary-button" disabled="@(!userIsDirty || isSavingUser)">
                                        @(isSavingUser ? "Saving..." : "Save")
                                    </button>
                                </div>
                            </EditForm>
                        </section>
                    </div>
                }
            }
            else if (ActiveSection == "articles")
            {
                @if (!EntityGuid.HasValue)
                {
                    <div class="detail-empty">
                        <p class="muted-text">Select an article to view and edit its details.</p>
                    </div>
                }
                else if (articleIsLoading)
                {
                    <p class="muted-text">Loading...</p>
                }
                else if (selectedArticle is null)
                {
                    <p class="muted-text">Article could not be loaded.</p>
                }
                else
                {
                    <div class="workspace-stack">
                        <section class="workspace-panel">
                            <EditForm Model="articleEditModel" OnValidSubmit="SaveArticleAsync" class="editor-form">
                                <DataAnnotationsValidator />
                                <label>
                                    <span>Name</span>
                                    <InputText @bind-Value="articleEditModel.Name" class="text-field" />
                                    <ValidationMessage For="() => articleEditModel.Name" />
                                </label>
                                <label>
                                    <span>Description</span>
                                    <InputTextArea @bind-Value="articleEditModel.Description" class="text-area" />
                                </label>
                                <div class="dialog-actions">
                                    <button type="submit" class="primary-button" disabled="@(!articleIsDirty || isSavingArticle)">
                                        @(isSavingArticle ? "Saving..." : "Save")
                                    </button>
                                </div>
                            </EditForm>
                        </section>
                    </div>
                }
            }
            else if (ActiveSection == "items")
            {
                @if (!EntityGuid.HasValue)
                {
                    <div class="detail-empty">
                        <p class="muted-text">Select an item to view its details.</p>
                    </div>
                }
                else if (itemIsLoading)
                {
                    <p class="muted-text">Loading...</p>
                }
                else if (selectedItem is null)
                {
                    <p class="muted-text">Item could not be loaded.</p>
                }
                else
                {
                    <div class="workspace-stack">
                        <section class="workspace-panel">
                            <dl class="detail-list detail-list--inline">
                                <div>
                                    <dt>Article</dt>
                                    <dd>@selectedItem.ArticleGuid</dd>
                                </div>
                            </dl>
                        </section>
                    </div>
                }
            }
            else
            {
                @* Partitions *@
                @if (!EntityGuid.HasValue)
                {
                    <div class="detail-empty">
                        <p class="muted-text">Select a partition to inspect its details and edit its description.</p>
                    </div>
                }
                else if (partitionIsLoading)
                {
                    <p class="muted-text">Loading...</p>
                }
                else if (selectedPartition is null)
                {
                    <p class="muted-text">Partition could not be loaded.</p>
                }
                else
                {
                    <div class="workspace-stack">
                        <section class="workspace-panel">
                            <dl class="detail-list detail-list--inline">
                                <div>
                                    <dt>Parent</dt>
                                    <dd>@(selectedPartition.ParentPartitionGuid?.ToString() ?? "Root")</dd>
                                </div>
                                <div>
                                    <dt>Status</dt>
                                    <dd>@(selectedPartition.IsActive ? "Active" : "Inactive")</dd>
                                </div>
                            </dl>
                            <EditForm Model="partitionEditModel" OnValidSubmit="SavePartitionAsync" class="editor-form">
                                <DataAnnotationsValidator />
                                @if (isGlobalPartition)
                                {
                                    <label>
                                        <span>Name</span>
                                        <input type="text" class="text-field" value="@selectedPartition.Name" disabled />
                                    </label>
                                }
                                else
                                {
                                    <label>
                                        <span>Name</span>
                                        <InputText @bind-Value="partitionEditModel.Name" class="text-field" />
                                        <ValidationMessage For="() => partitionEditModel.Name" />
                                    </label>
                                }
                                <label>
                                    <span>Description</span>
                                    <InputTextArea @bind-Value="partitionEditModel.Description" class="text-area" />
                                </label>
                                <div class="dialog-actions">
                                    <button type="button" class="ghost-button danger" @onclick="DeletePartitionAsync" disabled="@isDeletingPartition">
                                        @(isDeletingPartition ? "Deleting..." : "Delete")
                                    </button>
                                    <button type="submit" class="primary-button" disabled="@(!partitionIsDirty || isSavingPartition)">
                                        @(isSavingPartition ? "Saving..." : "Save")
                                    </button>
                                </div>
                            </EditForm>
                        </section>
                    </div>
                }
            }

        </div>
    </section>
</div>

@if (createDialogOpen)
{
    <div class="overlay">
        <section class="dialog-card">
            @if (!string.IsNullOrWhiteSpace(createErrorMessage))
            {
                <div class="error-banner">@createErrorMessage</div>
            }
            @if (ActiveSection == "articles")
            {
                <h2>New Article</h2>
                <EditForm Model="articleCreateModel" OnValidSubmit="CreateArticleAsync" class="editor-form">
                    <DataAnnotationsValidator />
                    <label>
                        <span>Name</span>
                        <InputText @bind-Value="articleCreateModel.Name" class="text-field" />
                        <ValidationMessage For="() => articleCreateModel.Name" />
                    </label>
                    <label>
                        <span>Description</span>
                        <InputTextArea @bind-Value="articleCreateModel.Description" class="text-area" />
                    </label>
                    <div class="dialog-actions">
                        <button type="button" class="ghost-button" @onclick="CloseCreateDialog" disabled="@isCreating">Cancel</button>
                        <button type="submit" class="primary-button" disabled="@isCreating">
                            @(isCreating ? "Creating..." : "Create")
                        </button>
                    </div>
                </EditForm>
            }
            else if (ActiveSection == "users")
            {
                <h2>New User</h2>
                <EditForm Model="userCreateModel" OnValidSubmit="CreateUserAsync" class="editor-form">
                    <DataAnnotationsValidator />
                    <label>
                        <span>NameId</span>
                        <InputText @bind-Value="userCreateModel.Nameid" class="text-field" />
                        <ValidationMessage For="() => userCreateModel.Nameid" />
                    </label>
                    <label>
                        <span>Password</span>
                        <input type="password" class="text-field" @bind="userCreateModel.Password" />
                        <ValidationMessage For="() => userCreateModel.Password" />
                    </label>
                    <div class="editor-form two-columns">
                        <label>
                            <span>First name</span>
                            <InputText @bind-Value="userCreateModel.FirstName" class="text-field" />
                        </label>
                        <label>
                            <span>Last name</span>
                            <InputText @bind-Value="userCreateModel.LastName" class="text-field" />
                        </label>
                    </div>
                    <label>
                        <span>Description</span>
                        <InputTextArea @bind-Value="userCreateModel.Description" class="text-area" />
                    </label>
                    <div class="dialog-actions">
                        <button type="button" class="ghost-button" @onclick="CloseCreateDialog" disabled="@isCreating">Cancel</button>
                        <button type="submit" class="primary-button" disabled="@isCreating">
                            @(isCreating ? "Creating..." : "Create")
                        </button>
                    </div>
                </EditForm>
            }
            else if (ActiveSection == "items")
            {
                <h2>New Item</h2>
                <EditForm Model="itemCreateModel" OnValidSubmit="CreateItemAsync" class="editor-form">
                    <DataAnnotationsValidator />
                    <label>
                        <span>Article GUID</span>
                        <InputText @bind-Value="itemCreateModel.ArticleGuid" class="text-field" />
                        <ValidationMessage For="() => itemCreateModel.ArticleGuid" />
                    </label>
                    <div class="dialog-actions">
                        <button type="button" class="ghost-button" @onclick="CloseCreateDialog" disabled="@isCreating">Cancel</button>
                        <button type="submit" class="primary-button" disabled="@isCreating">
                            @(isCreating ? "Creating..." : "Create")
                        </button>
                    </div>
                </EditForm>
            }
            else
            {
                @* Partitions *@
                <h2>New Partition</h2>
                <EditForm Model="partitionCreateModel" OnValidSubmit="CreatePartitionAsync" class="editor-form">
                    <DataAnnotationsValidator />
                    <label>
                        <span>Name</span>
                        <InputText @bind-Value="partitionCreateModel.Name" class="text-field" />
                        <ValidationMessage For="() => partitionCreateModel.Name" />
                    </label>
                    <label>
                        <span>Description</span>
                        <InputTextArea @bind-Value="partitionCreateModel.Description" class="text-area" />
                    </label>
                    <div class="dialog-actions">
                        <button type="button" class="ghost-button" @onclick="CloseCreateDialog" disabled="@isCreating">Cancel</button>
                        <button type="submit" class="primary-button" disabled="@isCreating">
                            @(isCreating ? "Creating..." : "Create")
                        </button>
                    </div>
                </EditForm>
            }
        </section>
    </div>
}

@code {
    [Parameter] public string? Section { get; set; }
    [Parameter] public Guid? EntityGuid { get; set; }

    private string ActiveSection => Section?.ToLowerInvariant() switch
    {
        "articles" => "articles",
        "users" => "users",
        "items" => "items",
        _ => "partitions"
    };

    private string ActiveSectionLabel => ActiveSection switch
    {
        "articles" => "Articles",
        "users" => "Users",
        "items" => "Items",
        _ => "Partitions"
    };

    private string ActiveSectionSingularLabel => ActiveSection switch
    {
        "articles" => "Article",
        "users" => "User",
        "items" => "Item",
        _ => "Partition"
    };

    private bool sectionPickerOpen;
    private string? errorMessage;

    // Computed partition properties
    private bool isGlobalPartition => selectedPartition?.ParentPartitionGuid == null;

    private bool partitionIsDirty => selectedPartition is not null && (
        (!isGlobalPartition && partitionEditModel.Name != _origPartitionName) ||
        (partitionEditModel.Description ?? "") != (_origPartitionDescription ?? ""));

    private bool articleIsDirty => selectedArticle is not null && (
        articleEditModel.Name != _origArticleName ||
        (articleEditModel.Description ?? "") != (_origArticleDescription ?? ""));

    private bool userIsDirty => selectedUser is not null && (
        userEditModel.Nameid != _origUserNameid ||
        (userEditModel.FirstName ?? "") != (_origUserFirstName ?? "") ||
        (userEditModel.LastName ?? "") != (_origUserLastName ?? "") ||
        (userEditModel.Description ?? "") != (_origUserDescription ?? ""));

    // Create dialog state
    private bool createDialogOpen;
    private bool isCreating;
    private string? createErrorMessage;
    private PartitionCreateForm partitionCreateModel = new();
    private ArticleCreateForm articleCreateModel = new();
    private UserCreateForm userCreateModel = new();
    private ItemCreateForm itemCreateModel = new();

    // Partition state
    private Fargo.Sdk.Partitions.Partition? selectedPartition;
    private bool partitionIsLoading;
    private bool isSavingPartition;
    private bool isDeletingPartition;
    private PartitionEditForm partitionEditModel = new();
    private string? _origPartitionName;
    private string? _origPartitionDescription;

    // Article state
    private Fargo.Sdk.Articles.Article? selectedArticle;
    private bool articleIsLoading;
    private bool isSavingArticle;
    private ArticleEditForm articleEditModel = new();
    private string? _origArticleName;
    private string? _origArticleDescription;

    // Item state
    private Fargo.Sdk.Items.Item? selectedItem;
    private bool itemIsLoading;

    // User state
    private Fargo.Sdk.Users.User? selectedUser;
    private bool userIsLoading;
    private bool isSavingUser;
    private UserEditForm userEditModel = new();
    private string? _origUserNameid;
    private string? _origUserFirstName;
    private string? _origUserLastName;
    private string? _origUserDescription;

    protected override Task OnParametersSetAsync()
    {
        sectionPickerOpen = false;
        errorMessage = null;

        if (!EntityGuid.HasValue)
        {
            selectedPartition = null;
            selectedArticle = null;
            selectedItem = null;
            selectedUser = null;
            partitionEditModel = new PartitionEditForm();
            articleEditModel = new ArticleEditForm();
            userEditModel = new UserEditForm();
            _origPartitionName = null;
            _origPartitionDescription = null;
            _origArticleName = null;
            _origArticleDescription = null;
            _origUserNameid = null;
            _origUserFirstName = null;
            _origUserLastName = null;
            _origUserDescription = null;
            return Task.CompletedTask;
        }

        _ = LoadEntityAndRenderAsync();
        return Task.CompletedTask;
    }

    private async Task LoadEntityAndRenderAsync()
    {
        switch (ActiveSection)
        {
            case "partitions":
                await LoadPartitionAsync();
                break;
            case "articles":
                await LoadArticleAsync();
                break;
            case "items":
                await LoadItemAsync();
                break;
            case "users":
                await LoadUserAsync();
                break;
        }
        await InvokeAsync(StateHasChanged);
    }

    private void TogglePicker() => sectionPickerOpen = !sectionPickerOpen;
    private void ClosePicker() => sectionPickerOpen = false;

    private void OpenCreateDialog()
    {
        createDialogOpen = true;
        createErrorMessage = null;
        partitionCreateModel = new PartitionCreateForm();
        articleCreateModel = new ArticleCreateForm();
        userCreateModel = new UserCreateForm();
        itemCreateModel = new ItemCreateForm();
    }

    private void CloseCreateDialog()
    {
        createDialogOpen = false;
        createErrorMessage = null;
    }

    // Partition

    private async Task LoadPartitionAsync()
    {
        selectedPartition = null;
        partitionEditModel = new PartitionEditForm();
        partitionIsLoading = true;

        try
        {
            selectedPartition = await Engine.Partitions.GetAsync(EntityGuid!.Value);
            partitionEditModel.Name = selectedPartition.Name;
            partitionEditModel.Description = selectedPartition.Description;
            _origPartitionName = selectedPartition.Name;
            _origPartitionDescription = selectedPartition.Description;
        }
        catch (FargoSdkApiException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to load partition." : ex.Message;
        }
        finally
        {
            partitionIsLoading = false;
        }
    }

    private async Task SavePartitionAsync()
    {
        if (selectedPartition is null) return;

        isSavingPartition = true;
        errorMessage = null;

        try
        {
            await selectedPartition.UpdateAsync(p =>
            {
                if (!isGlobalPartition && partitionEditModel.Name is not null)
                    p.Name = partitionEditModel.Name;
                p.Description = partitionEditModel.Description ?? string.Empty;
            });
            await LoadPartitionAsync();
        }
        catch (FargoSdkApiException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to save." : ex.Message;
        }
        finally
        {
            isSavingPartition = false;
        }
    }

    private async Task CreatePartitionAsync()
    {
        isCreating = true;
        createErrorMessage = null;

        try
        {
            var partition = await Engine.Partitions.CreateAsync(
                partitionCreateModel.Name!,
                partitionCreateModel.Description,
                EntityGuid.HasValue ? EntityGuid.Value : null);
            Navigation.NavigateTo($"/entities/partitions/{partition.Guid}", forceLoad: true);
        }
        catch (FargoSdkApiException ex)
        {
            createErrorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to create." : ex.Message;
        }
        finally
        {
            isCreating = false;
        }
    }

    private async Task DeletePartitionAsync()
    {
        if (!EntityGuid.HasValue) return;

        isDeletingPartition = true;
        errorMessage = null;

        try
        {
            await Engine.Partitions.DeleteAsync(EntityGuid.Value);
            Navigation.NavigateTo("/entities/partitions", forceLoad: true);
        }
        catch (FargoSdkApiException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to delete." : ex.Message;
        }
        finally
        {
            isDeletingPartition = false;
        }
    }

    // Article

    private async Task LoadArticleAsync()
    {
        selectedArticle = null;
        articleEditModel = new ArticleEditForm();
        articleIsLoading = true;

        try
        {
            selectedArticle = await Engine.Articles.GetAsync(EntityGuid!.Value);
            articleEditModel.Name = selectedArticle.Name;
            articleEditModel.Description = selectedArticle.Description;
            _origArticleName = selectedArticle.Name;
            _origArticleDescription = selectedArticle.Description;
        }
        catch (FargoSdkApiException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to load article." : ex.Message;
        }
        finally
        {
            articleIsLoading = false;
        }
    }

    private async Task SaveArticleAsync()
    {
        if (selectedArticle is null) return;

        isSavingArticle = true;
        errorMessage = null;

        try
        {
            await selectedArticle.UpdateAsync(a =>
            {
                a.Name = articleEditModel.Name!;
                a.Description = articleEditModel.Description ?? string.Empty;
            });
            await LoadArticleAsync();
        }
        catch (FargoSdkApiException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to save." : ex.Message;
        }
        finally
        {
            isSavingArticle = false;
        }
    }

    private async Task CreateArticleAsync()
    {
        isCreating = true;
        createErrorMessage = null;

        try
        {
            var article = await Engine.Articles.CreateAsync(
                articleCreateModel.Name!,
                articleCreateModel.Description);
            Navigation.NavigateTo($"/entities/articles/{article.Guid}", forceLoad: true);
        }
        catch (FargoSdkApiException ex)
        {
            createErrorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to create." : ex.Message;
        }
        finally
        {
            isCreating = false;
        }
    }

    // Item

    private async Task LoadItemAsync()
    {
        selectedItem = null;
        itemIsLoading = true;

        try
        {
            selectedItem = await Engine.Items.GetAsync(EntityGuid!.Value);
        }
        catch (FargoSdkApiException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to load item." : ex.Message;
        }
        finally
        {
            itemIsLoading = false;
        }
    }

    private async Task CreateItemAsync()
    {
        isCreating = true;
        createErrorMessage = null;

        try
        {
            if (!Guid.TryParse(itemCreateModel.ArticleGuid, out var articleGuid))
            {
                createErrorMessage = "Invalid article GUID.";
                return;
            }
            var item = await Engine.Items.CreateAsync(articleGuid);
            Navigation.NavigateTo($"/entities/items/{item.Guid}", forceLoad: true);
        }
        catch (FargoSdkApiException ex)
        {
            createErrorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to create." : ex.Message;
        }
        finally
        {
            isCreating = false;
        }
    }

    // User

    private async Task LoadUserAsync()
    {
        selectedUser = null;
        userEditModel = new UserEditForm();
        userIsLoading = true;

        try
        {
            selectedUser = await Engine.Users.GetAsync(EntityGuid!.Value);
            userEditModel.Nameid = selectedUser.Nameid;
            userEditModel.FirstName = selectedUser.FirstName;
            userEditModel.LastName = selectedUser.LastName;
            userEditModel.Description = selectedUser.Description;
            _origUserNameid = selectedUser.Nameid;
            _origUserFirstName = selectedUser.FirstName;
            _origUserLastName = selectedUser.LastName;
            _origUserDescription = selectedUser.Description;
        }
        catch (FargoSdkApiException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to load user." : ex.Message;
        }
        finally
        {
            userIsLoading = false;
        }
    }

    private async Task SaveUserAsync()
    {
        if (selectedUser is null) return;

        isSavingUser = true;
        errorMessage = null;

        try
        {
            await selectedUser.UpdateAsync(u =>
            {
                u.Nameid = userEditModel.Nameid!;
                u.FirstName = string.IsNullOrWhiteSpace(userEditModel.FirstName) ? null : userEditModel.FirstName;
                u.LastName = string.IsNullOrWhiteSpace(userEditModel.LastName) ? null : userEditModel.LastName;
                u.Description = userEditModel.Description ?? string.Empty;
            });
            await LoadUserAsync();
        }
        catch (FargoSdkApiException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to save." : ex.Message;
        }
        finally
        {
            isSavingUser = false;
        }
    }

    private async Task CreateUserAsync()
    {
        isCreating = true;
        createErrorMessage = null;

        try
        {
            var user = await Engine.Users.CreateAsync(
                userCreateModel.Nameid!,
                userCreateModel.Password!,
                string.IsNullOrWhiteSpace(userCreateModel.FirstName) ? null : userCreateModel.FirstName,
                string.IsNullOrWhiteSpace(userCreateModel.LastName) ? null : userCreateModel.LastName,
                userCreateModel.Description);
            Navigation.NavigateTo($"/entities/users/{user.Guid}", forceLoad: true);
        }
        catch (FargoSdkApiException ex)
        {
            createErrorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to create." : ex.Message;
        }
        finally
        {
            isCreating = false;
        }
    }

    // Form models

    private sealed class PartitionCreateForm
    {
        [Required(ErrorMessage = "Name is required.")]
        public string? Name { get; set; }
        public string? Description { get; set; }
    }

    private sealed class PartitionEditForm
    {
        [Required(ErrorMessage = "Name is required.")]
        [StringLength(100, MinimumLength = 3, ErrorMessage = "Name must be between 3 and 100 characters.")]
        public string? Name { get; set; }
        public string? Description { get; set; }
    }

    private sealed class ArticleCreateForm
    {
