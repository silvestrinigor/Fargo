@page "/login"
@layout LoginLayout
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Fargo.Application.Commands.AuthCommands
@using Fargo.Application.Models.AuthModels
@using Fargo.Domain.ValueObjects
@using Fargo.Web.Security
@inject AuthenticationApi AuthenticationApi
@inject IClientSessionStore SessionStore
@inject ClientSessionAccessor SessionAccessor
@inject NavigationManager Navigation

<PageTitle>Login | Fargo</PageTitle>

<div class="login-page">
    <section class="login-card">
        <div class="hero-badge">F</div>
        <h1>Fargo</h1>
        <p class="muted-text">
            Start with a simple front end, but already keep the structure ready for future modules,
            tree navigation, and richer admin workflows.
        </p>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="error-banner">@errorMessage</div>
        }

        <EditForm Model="model" OnValidSubmit="HandleLoginAsync" class="editor-form">
            <DataAnnotationsValidator />

            <label>
                <span>NameId</span>
                <InputText @bind-Value="model.Nameid" class="text-field" />
                <ValidationMessage For="() => model.Nameid" />
            </label>

            <label>
                <span>Password</span>
                <InputText @bind-Value="model.Password" Type="password" class="text-field" />
                <ValidationMessage For="() => model.Password" />
            </label>

            <label class="checkbox-row">
                <InputCheckbox @bind-Value="model.RememberMe" />
                <span>Keep session on this browser</span>
            </label>

            <button type="submit" class="primary-button" disabled="@isSubmitting">
                @(isSubmitting ? "Signing in..." : "Sign in")
            </button>
        </EditForm>
    </section>
</div>

@code {
    private readonly LoginInputModel model = new();
    private bool isSubmitting;
    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || SessionAccessor.IsAuthenticated)
        {
            return;
        }

        try
        {
            var session = await SessionStore.GetAsync();

            if (!string.IsNullOrWhiteSpace(session?.AccessToken))
            {
                SessionAccessor.SetSession(session);
                Navigation.NavigateTo("/workspace", replace: true);
            }
        }
        catch
        {
            SessionAccessor.MarkReady();
        }
    }

    private async Task HandleLoginAsync()
    {
        if (isSubmitting)
        {
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        try
        {
            var command = new LoginCommand(
                new Nameid(model.Nameid!),
                new Password(model.Password!));

            var result = await AuthenticationApi.LoginAsync(command);

            var session = new AuthenticatedSession
            {
                AccessToken = result.AccessToken.ToString(),
                RefreshToken = result.RefreshToken.ToString(),
                ExpiresAt = result.ExpiresAt
            };

            await SessionStore.SaveAsync(session, model.RememberMe);
            SessionAccessor.SetSession(session);

            Navigation.NavigateTo("/workspace", replace: true);
        }
        catch (HttpRequestException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Unable to sign in with the provided credentials."
                : ex.Message;
        }
        catch
        {
            errorMessage = "An unexpected error happened while trying to sign in.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class LoginInputModel
    {
        [Required(ErrorMessage = "NameId is required.")]
        public string? Nameid { get; set; }

        [Required(ErrorMessage = "Password is required.")]
        public string? Password { get; set; }

        public bool RememberMe { get; set; } = true;
    }
}