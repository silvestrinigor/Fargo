@page "/articles"
@page "/articles/{ArticleGuid:guid}"

<PageTitle>Articles | Fargo</PageTitle>

<SectionWorkspace Title="Articles"
                  Description="The article tree now lives inside the Articles section workspace, so the explorer and the selected article context feel like one block."
                  ExplorerTitle="Article tree"
                  ExplorerDescription="Select an article to drive the article detail surface and future related item panels.">
    <ExplorerContent>
        <ArticleTree />
    </ExplorerContent>

    <ExplorerFooter>
        <p class="explorer-caption">The left pane now reads as the article explorer for this module instead of a separate app sidebar.</p>
    </ExplorerFooter>

    <DetailContent>
        @if (!ArticleGuid.HasValue)
        {
            <div class="workspace-empty-state">
                <div class="workspace-panel-grid workspace-panel-grid--three">
                    <article class="workspace-panel">
                        <h2>Article-first navigation</h2>
                        <p>The explorer stays visible while the right side changes with the selected article.</p>
                    </article>

                    <article class="workspace-panel">
                        <h2>Unified section surface</h2>
                        <p>The tree and the article details share the same visual block, which makes the section feel more coherent.</p>
                    </article>

                    <article class="workspace-panel">
                        <h2>Ready for items</h2>
                        <p>The selected article can later anchor related items, stock, and location information in this same area.</p>
                    </article>
                </div>

                <section class="workspace-panel workspace-panel--soft">
                    <h2>Select an article</h2>
                    <p class="muted-text">Choose a node in the tree to inspect the selected article context on the right.</p>
                </section>
            </div>
        }
        else
        {
            <div class="workspace-stack">
                <div class="workspace-panel-grid">
                    <article class="workspace-panel">
                        <h2>@ResolvedTitle</h2>
                        <p>@(string.IsNullOrWhiteSpace(Subtitle) ? "No subtitle informed for this tree node." : Subtitle)</p>

                        <dl class="detail-list">
                            <div>
                                <dt>Guid</dt>
                                <dd>@ArticleGuid</dd>
                            </div>
                            <div>
                                <dt>Members count</dt>
                                <dd>@(MembersCount?.ToString() ?? "Not informed")</dd>
                            </div>
                            <div>
                                <dt>Status</dt>
                                <dd>@(IsActive == false ? "Inactive" : "Active")</dd>
                            </div>
                        </dl>
                    </article>

                    <article class="workspace-panel">
                        <h2>Next module binding</h2>
                        <p>The selected article is now the navigation anchor for the article workspace.</p>
                        <p class="muted-text">Next step: bind article details, related items, and inventory/location panels to this selected node.</p>
                    </article>
                </div>

                <section class="workspace-panel workspace-panel--soft">
                    <h2>Articles workspace context</h2>
                    <p class="muted-text">This area is ready to host detailed article information and future item-related panels while keeping the explorer visible on the left.</p>
                </section>
            </div>
        }
    </DetailContent>
</SectionWorkspace>

@code {
    [Parameter]
    public Guid? ArticleGuid { get; set; }

    [SupplyParameterFromQuery(Name = "title")]
    public string? Title { get; set; }

    [SupplyParameterFromQuery(Name = "subtitle")]
    public string? Subtitle { get; set; }

    [SupplyParameterFromQuery(Name = "membersCount")]
    public int? MembersCount { get; set; }

    [SupplyParameterFromQuery(Name = "active")]
    public bool? IsActive { get; set; }

    private string ResolvedTitle => string.IsNullOrWhiteSpace(Title)
        ? ArticleGuid?.ToString() ?? "Selected article"
        : Title;
}
