@page "/users"
@page "/users/groups/{UserGroupGuid:guid}"
@rendermode InteractiveServer

<PageTitle>Users | Fargo</PageTitle>

<SectionWorkspace Title="Users"
                  Description="The tree on the left is now visually part of the Users section, so the selected group and the detail surface read as one workspace."
                  ExplorerTitle="User groups tree"
                  ExplorerDescription="Select a user group to anchor the users workspace. The right pane can then host group information, permissions, and related users.">
    <ExplorerContent>
        <UserGroupTree />
    </ExplorerContent>

    <ExplorerFooter>
        <p class="explorer-caption">This explorer is local to the Users workspace and shares the same surface as the detail pane.</p>
    </ExplorerFooter>

    <DetailContent>
        @if (!UserGroupGuid.HasValue)
        {
            <div class="workspace-empty-state">
                <div class="workspace-panel-grid workspace-panel-grid--three">
                    <article class="workspace-panel">
                        <h2>Group-first navigation</h2>
                        <p>The left tree gives the users module its own navigation spine without looking like a global sidebar.</p>
                    </article>

                    <article class="workspace-panel">
                        <h2>Shared workspace surface</h2>
                        <p>The explorer and the details now feel like two panes inside the same section block.</p>
                    </article>

                    <article class="workspace-panel">
                        <h2>Ready for permissions</h2>
                        <p>The selected node can drive user-group details, partition access, and permission editing in the same view.</p>
                    </article>
                </div>

                <section class="workspace-panel workspace-panel--soft">
                    <h2>Select a user group</h2>
                    <p class="muted-text">Choose a node in the tree to inspect the selected group context on the right.</p>
                </section>
            </div>
        }
        else
        {
            <div class="workspace-stack">
                <div class="workspace-panel-grid">
                    <article class="workspace-panel">
                        <h2>@ResolvedTitle</h2>
                        <p>@(string.IsNullOrWhiteSpace(Subtitle) ? "No subtitle informed for this tree node." : Subtitle)</p>

                        <dl class="detail-list">
                            <div>
                                <dt>Guid</dt>
                                <dd>@UserGroupGuid</dd>
                            </div>
                            <div>
                                <dt>Members count</dt>
                                <dd>@(MembersCount?.ToString() ?? "Not informed")</dd>
                            </div>
                            <div>
                                <dt>Status</dt>
                                <dd>@(IsActive == false ? "Inactive" : "Active")</dd>
                            </div>
                        </dl>
                    </article>

                    <article class="workspace-panel">
                        <h2>Next module binding</h2>
                        <p>The selected user group is now the navigation anchor for the right pane.</p>
                        <p class="muted-text">Next step: bind group details, users inside the group, permissions, and partition security to this selected node.</p>
                    </article>
                </div>

                <section class="workspace-panel workspace-panel--soft">
                    <h2>Users workspace context</h2>
                    <p class="muted-text">This section is ready to host the user list, user editor, group membership, and partition security panels while keeping the tree visible on the left.</p>
                </section>
            </div>
        }
    </DetailContent>
</SectionWorkspace>

@code {
    [Parameter]
    public Guid? UserGroupGuid { get; set; }

    [SupplyParameterFromQuery(Name = "title")]
    public string? Title { get; set; }

    [SupplyParameterFromQuery(Name = "subtitle")]
    public string? Subtitle { get; set; }

    [SupplyParameterFromQuery(Name = "membersCount")]
    public int? MembersCount { get; set; }

    [SupplyParameterFromQuery(Name = "active")]
    public bool? IsActive { get; set; }

    private string ResolvedTitle => string.IsNullOrWhiteSpace(Title)
        ? UserGroupGuid?.ToString() ?? "Selected user group"
        : Title;
}
