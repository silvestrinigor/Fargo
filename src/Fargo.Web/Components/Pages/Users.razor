@page "/users"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Fargo.Application.Models.UserModels
@using Fargo.HttpApi.Client.Contracts
@using Fargo.Domain.ValueObjects;
@inject IUserClient UserClient

<PageTitle>Users | Fargo</PageTitle>

<div class="users-page">
    <div class="users-header">
        <div>
            <h1 class="page-title">Users</h1>
            <p class="page-subtitle">Manage system users.</p>
        </div>

        <div class="header-actions">
            <FluentButton Appearance="Appearance.Neutral" @onclick="LoadUsersAsync" Disabled="_isLoading">
                Refresh
            </FluentButton>

            <FluentButton Appearance="Appearance.Accent" @onclick="OpenCreateDialog">
                New user
            </FluentButton>
        </div>
    </div>

    <FluentCard Class="users-toolbar" MinimalStyle="true">
        <FluentTextField Label="Search" Placeholder="Search by username" Immediate="true" @bind-Value="_searchTerm" />

        <FluentButton Appearance="Appearance.Neutral" @onclick="ApplyFilter">
            Search
        </FluentButton>

        <FluentButton Appearance="Appearance.Stealth" @onclick="ClearFilter">
            Clear
        </FluentButton>
    </FluentCard>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <FluentMessageBar Intent="MessageIntent.Error" Title="Error" AllowDismiss="false">
            @_errorMessage
        </FluentMessageBar>
    }

    <FluentCard Class="users-content" MinimalStyle="true">
        @if (_isLoading)
        {
            <div class="state-box">
                <FluentProgressRing />
                <span>Loading users...</span>
            </div>
        }
        else if (_filteredUsers.Count == 0)
        {
            <div class="state-box empty-state">
                <span>No users found.</span>
            </div>
        }
        else
        {
            <div class="table-wrapper">
                <table class="users-table">
                    <thead>
                        <tr>
                            <th>Username</th>
                            <th>First name</th>
                            <th>Last name</th>
                            <th>Description</th>
                            <th class="actions-column">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in _filteredUsers)
                        {
                            <tr>
                                <td>@user.Nameid</td>
                                <td>@user.FirstName</td>
                                <td>@user.LastName</td>
                                <td>@user.Description</td>
                                <td class="actions-cell">
                                    <FluentButton Appearance="Appearance.Stealth" @onclick="() => OpenEditDialog(user)">
                                        Edit
                                    </FluentButton>

                                    <FluentButton Appearance="Appearance.Stealth" @onclick="() => OpenDeleteDialog(user)">
                                        Delete
                                    </FluentButton>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </FluentCard>
</div>

@if (_isEditorOpen)
{
    <div class="dialog-backdrop">
        <FluentCard Class="dialog-card" MinimalStyle="true">
            <EditForm Model="_editorModel" OnValidSubmit="SaveAsync">
                <DataAnnotationsValidator />

                <FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
                    <div>
                        <h2 class="dialog-title">@(_isEditing ? "Edit user" : "New user")</h2>
                    </div>

                    <div class="field-group">
                        <FluentTextField Label="Username" Name="nameid" Required="true" @bind-Value="_editorModel.Nameid" />
                        <ValidationMessage For="@(() => _editorModel.Nameid)" />
                    </div>

                    <div class="field-group">
                        <FluentTextField Label="First name" Name="firstName" @bind-Value="_editorModel.FirstName" />
                        <ValidationMessage For="@(() => _editorModel.FirstName)" />
                    </div>

                    <div class="field-group">
                        <FluentTextField Label="Last name" Name="lastName" @bind-Value="_editorModel.LastName" />
                        <ValidationMessage For="@(() => _editorModel.LastName)" />
                    </div>

                    <div class="field-group">
                        <FluentTextArea Label="Description" Name="description" Rows="4"
                                        @bind-Value="_editorModel.Description" />
                        <ValidationMessage For="@(() => _editorModel.Description)" />
                    </div>

                    @if (!_isEditing)
                    {
                        <div class="field-group">
                            <FluentTextField Label="Password" Name="password" Required="true"
                                             TextFieldType="TextFieldType.Password" @bind-Value="_editorModel.Password" />
                            <ValidationMessage For="@(() => _editorModel.Password)" />
                        </div>
                    }

                    <div class="dialog-actions">
                        <FluentButton Appearance="Appearance.Neutral" @onclick="CloseEditorDialog" Disabled="_isSaving">
                            Cancel
                        </FluentButton>

                        <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Accent" Loading="_isSaving"
                                      Disabled="_isSaving">
                            Save
                        </FluentButton>
                    </div>
                </FluentStack>
            </EditForm>
        </FluentCard>
    </div>
}

@if (_userPendingDelete is not null)
{
    <div class="dialog-backdrop">
        <FluentCard Class="dialog-card delete-card" MinimalStyle="true">
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
                <div>
                    <h2 class="dialog-title">Delete user</h2>
                    <p class="dialog-text">
                        Are you sure you want to delete <strong>@_userPendingDelete.Nameid</strong>?
                    </p>
                </div>

                <div class="dialog-actions">
                    <FluentButton Appearance="Appearance.Neutral" @onclick="CloseDeleteDialog" Disabled="_isDeleting">
                        Cancel
                    </FluentButton>

                    <FluentButton Appearance="Appearance.Accent" @onclick="DeleteAsync" Loading="_isDeleting"
                                  Disabled="_isDeleting">
                        Delete
                    </FluentButton>
                </div>
            </FluentStack>
        </FluentCard>
    </div>
}

@code {
    private readonly List<UserInformation> _users = [];
    private readonly List<UserInformation> _filteredUsers = [];

    private bool _isLoading;
    private bool _isSaving;
    private bool _isDeleting;
    private bool _isEditorOpen;
    private bool _isEditing;

    private string? _errorMessage;
    private string? _searchTerm;

    private Guid? _editingUserGuid;
    private UserInformation? _userPendingDelete;

    private UserEditorModel _editorModel = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var users = await UserClient.GetManyAsync();

            _users.Clear();
            _users.AddRange(users.OrderBy(x => x.Nameid.ToString()));

            ApplyFilter();
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Failed to load users."
                : ex.Message;
        }
        catch
        {
            _errorMessage = "Unexpected error while loading users.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ApplyFilter()
    {
        _filteredUsers.Clear();

        IEnumerable<UserInformation> query = _users;

        if (!string.IsNullOrWhiteSpace(_searchTerm))
        {
            query = query.Where(x =>
                (x.Nameid.ToString() ?? string.Empty)
                .Contains(_searchTerm, StringComparison.OrdinalIgnoreCase));
        }

        _filteredUsers.AddRange(query);
    }

    private void ClearFilter()
    {
        _searchTerm = null;
        ApplyFilter();
    }

    private void OpenCreateDialog()
    {
        _isEditing = false;
        _editingUserGuid = null;
        _editorModel = new UserEditorModel();
        _isEditorOpen = true;
    }

    private void OpenEditDialog(UserInformation user)
    {
        _isEditing = true;
        _editingUserGuid = user.Guid;

        _editorModel = new UserEditorModel
        {
            Nameid = user.Nameid.ToString(),
            FirstName = user.FirstName.ToString(),
            LastName = user.LastName.ToString(),
            Description = user.Description.ToString()
        };

        _isEditorOpen = true;
    }

    private void CloseEditorDialog()
    {
        if (_isSaving)
            return;

        _isEditorOpen = false;
    }

    private async Task SaveAsync()
    {
        _isSaving = true;
        _errorMessage = null;

        try
        {
            if (_isEditing && _editingUserGuid.HasValue)
            {
                var updateModel = new UserUpdateModel(
                    Nameid: string.IsNullOrWhiteSpace(_editorModel.Nameid) ? null : new(_editorModel.Nameid),
                    FirstName: string.IsNullOrWhiteSpace(_editorModel.FirstName) ? null : new(_editorModel.FirstName),
                    LastName: string.IsNullOrWhiteSpace(_editorModel.LastName) ? null : new(_editorModel.LastName),
                    Description: string.IsNullOrWhiteSpace(_editorModel.Description) ? null : new(_editorModel.Description),
                    Password: null,
                    IsActive: null,
                    Permissions: null
                );

                await UserClient.UpdateAsync(_editingUserGuid.Value, updateModel);
            }
            else
            {
                var createModel = new UserCreateModel(
                    Nameid: new(_editorModel.Nameid!),
                    FirstName: string.IsNullOrWhiteSpace(_editorModel.FirstName) ? null : new(_editorModel.FirstName),
                    LastName: string.IsNullOrWhiteSpace(_editorModel.LastName) ? null : new(_editorModel.LastName),
                    Description: string.IsNullOrWhiteSpace(_editorModel.Description) ? null : new(_editorModel.Description),
                    Password: new(_editorModel.Password!)
                );

                await UserClient.CreateAsync(createModel);
            }

            _isEditorOpen = false;
            await LoadUsersAsync();
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Failed to save user."
                : ex.Message;
        }
        catch
        {
            _errorMessage = "Unexpected error while saving user.";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void OpenDeleteDialog(UserInformation user)
    {
        _userPendingDelete = user;
    }

    private void CloseDeleteDialog()
    {
        if (_isDeleting)
            return;

        _userPendingDelete = null;
    }

    private async Task DeleteAsync()
    {
        if (_userPendingDelete is null)
            return;

        _isDeleting = true;
        _errorMessage = null;

        try
        {
            await UserClient.DeleteAsync(_userPendingDelete.Guid);
            _userPendingDelete = null;
            await LoadUsersAsync();
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Failed to delete user."
                : ex.Message;
        }
        catch
        {
            _errorMessage = "Unexpected error while deleting user.";
        }
        finally
        {
            _isDeleting = false;
        }
    }

    private sealed class UserEditorModel
    {
        [Required(ErrorMessage = "Username is required.")]
        public string? Nameid { get; set; }

        public string? FirstName { get; set; }

        public string? LastName { get; set; }

        public string? Description { get; set; }

        public string? Password { get; set; }
    }
}