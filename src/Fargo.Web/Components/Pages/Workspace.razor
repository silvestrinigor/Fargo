@page "/workspace"
@page "/workspace/partitions/{PartitionGuid:guid}"
@inject PartitionApi PartitionApi
@inject NavigationManager Navigation

<PageTitle>Workspace | Fargo</PageTitle>

<div class="page-card">
    <div class="section-header">
        <div>
            <h1>Workspace</h1>
            <p>
                First implementation keeps the experience simple, but it is already structured around
                a persistent shell, a left partition tree, and reusable feature modules.
            </p>
        </div>

        <div class="section-actions">
            @if (PartitionGuid.HasValue)
            {
                <button type="button" class="ghost-button" @onclick="ReloadAsync">Refresh</button>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="error-banner">@errorMessage</div>
    }

    @if (!PartitionGuid.HasValue)
    {
        <div class="hero-grid">
            <article class="mini-card">
                <h2>Tree-ready shell</h2>
                <p>The left side already behaves as the permanent navigation spine for partitions and future modules.</p>
            </article>

            <article class="mini-card">
                <h2>Modular composition</h2>
                <p>Users are handled in a separate module, and partitions are isolated behind their own API service and view state.</p>
            </article>

            <article class="mini-card">
                <h2>Future expansion</h2>
                <p>Articles, items, containers, and more domain trees can plug into the same shell later.</p>
            </article>
        </div>

        <p class="muted-text">Select a partition on the left to inspect it or create child partitions.</p>
    }
    else if (isLoading)
    {
        <p class="muted-text">Loading partition...</p>
    }
    else if (selectedPartition is null)
    {
        <p class="muted-text">The selected partition could not be loaded.</p>
    }
    else
    {
        <div class="hero-grid two-columns-layout">
            <article class="mini-card">
                <h2>@selectedPartition.Name</h2>
                <p>@(string.IsNullOrWhiteSpace(selectedPartition.Description) ? "No description informed." : selectedPartition.Description)</p>

                <dl class="detail-list">
                    <div>
                        <dt>Guid</dt>
                        <dd>@selectedPartition.Guid</dd>
                    </div>
                    <div>
                        <dt>Parent</dt>
                        <dd>@(selectedPartition.ParentPartitionGuid?.ToString() ?? "Root partition")</dd>
                    </div>
                    <div>
                        <dt>Status</dt>
                        <dd>@(selectedPartition.IsActive ? "Active" : "Inactive")</dd>
                    </div>
                </dl>
            </article>

            <article class="mini-card">
                <h2>Create child partition</h2>

                <EditForm Model="createModel" OnValidSubmit="CreateChildAsync" class="editor-form">
                    <DataAnnotationsValidator />

                    <label>
                        <span>Name</span>
                        <InputText @bind-Value="createModel.Name" class="text-field" />
                        <ValidationMessage For="() => createModel.Name" />
                    </label>

                    <label>
                        <span>Description</span>
                        <InputTextArea @bind-Value="createModel.Description" class="text-area" />
                    </label>

                    <div class="dialog-actions">
                        <button type="submit" class="primary-button" disabled="@isCreatingChild">
                            @(isCreatingChild ? "Creating..." : "Create child")
                        </button>
                    </div>
                </EditForm>
            </article>
        </div>

        <section class="page-card nested-card">
            <h2>Edit description</h2>

            <EditForm Model="editModel" OnValidSubmit="SaveAsync" class="editor-form">
                <DataAnnotationsValidator />
                <label>
                    <span>Description</span>
                    <InputTextArea @bind-Value="editModel.Description" class="text-area" />
                </label>

                <div class="dialog-actions">
                    <button type="submit" class="primary-button" disabled="@isSaving">
                        @(isSaving ? "Saving..." : "Save changes")
                    </button>
                    <button type="button" class="ghost-button danger" @onclick="DeleteAsync" disabled="@isDeleting">
                        @(isDeleting ? "Deleting..." : "Delete partition")
                    </button>
                </div>
            </EditForm>
        </section>
    }
</div>

@code {
    [Parameter]
    public Guid? PartitionGuid { get; set; }

    private PartitionSummary? selectedPartition;
    private string? errorMessage;
    private bool isLoading;
    private bool isSaving;
    private bool isDeleting;
    private bool isCreatingChild;
    private PartitionCreateForm createModel = new();
    private PartitionEditForm editModel = new();

    protected override async Task OnParametersSetAsync()
    {
        await LoadSelectedPartitionAsync();
    }

    private async Task LoadSelectedPartitionAsync()
    {
        errorMessage = null;
        selectedPartition = null;
        createModel = new PartitionCreateForm();
        editModel = new PartitionEditForm();

        if (!PartitionGuid.HasValue)
        {
            return;
        }

        isLoading = true;

        try
        {
            selectedPartition = await PartitionApi.GetSingleAsync(PartitionGuid.Value);
            editModel.Description = selectedPartition?.Description;
        }
        catch (HttpRequestException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to load partition." : ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ReloadAsync()
    {
        await LoadSelectedPartitionAsync();
    }

    private async Task SaveAsync()
    {
        if (!PartitionGuid.HasValue)
        {
            return;
        }

        isSaving = true;
        errorMessage = null;

        try
        {
            await PartitionApi.UpdateAsync(PartitionGuid.Value, editModel.Description);
            await LoadSelectedPartitionAsync();
        }
        catch (HttpRequestException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to save partition changes." : ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task CreateChildAsync()
    {
        if (!PartitionGuid.HasValue)
        {
            return;
        }

        isCreatingChild = true;
        errorMessage = null;

        try
        {
            var newPartitionGuid = await PartitionApi.CreateAsync(createModel.Name!, createModel.Description, PartitionGuid.Value);
            Navigation.NavigateTo($"/workspace/partitions/{newPartitionGuid}", forceLoad: true);
        }
        catch (HttpRequestException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to create child partition." : ex.Message;
        }
        finally
        {
            isCreatingChild = false;
        }
    }

    private async Task DeleteAsync()
    {
        if (!PartitionGuid.HasValue)
        {
            return;
        }

        isDeleting = true;
        errorMessage = null;

        try
        {
            await PartitionApi.DeleteAsync(PartitionGuid.Value);
            Navigation.NavigateTo("/workspace", forceLoad: true);
        }
        catch (HttpRequestException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to delete partition." : ex.Message;
        }
        finally
        {
            isDeleting = false;
        }
    }

    private sealed class PartitionCreateForm
    {
        [Required(ErrorMessage = "Name is required.")]
        public string? Name { get; set; }

        public string? Description { get; set; }
    }

    private sealed class PartitionEditForm
    {
        public string? Description { get; set; }
    }
}
