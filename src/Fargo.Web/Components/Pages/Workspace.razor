@page "/partitions"
@page "/partitions/{PartitionGuid:guid}"
@page "/workspace"
@page "/workspace/partitions/{PartitionGuid:guid}"
@inject IEngine Engine
@inject NavigationManager Navigation

<PageTitle>Partitions | Fargo</PageTitle>

<SectionWorkspace Title="Partitions"
                  Description="The partition tree is now part of the Partitions workspace itself, with the explorer and details sharing the same surface."
                  ExplorerTitle="Partition tree"
                  ExplorerDescription="Select a partition to inspect it, edit it, or create a child partition without leaving this section.">
    <HeaderActions>
        @if (PartitionGuid.HasValue)
        {
            <button type="button" class="ghost-button" @onclick="ReloadAsync">Refresh</button>
        }
    </HeaderActions>

    <ExplorerContent>
        <PartitionTree />
    </ExplorerContent>

    <ExplorerFooter>
        <p class="explorer-caption">The explorer belongs to the Partitions section now, instead of feeling like a global sidebar.</p>
    </ExplorerFooter>

    <DetailContent>
        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="error-banner">@errorMessage</div>
        }

        @if (!PartitionGuid.HasValue)
        {
            <div class="workspace-empty-state">
                <div class="workspace-panel-grid workspace-panel-grid--three">
                    <article class="workspace-panel">
                        <h2>Tree-first navigation</h2>
                        <p>The hierarchy stays visible while you work, so moving between parent and child partitions feels local to this module.</p>
                    </article>

                    <article class="workspace-panel">
                        <h2>Detail-first editing</h2>
                        <p>Selection opens the partition details on the right without breaking the context of the tree.</p>
                    </article>

                    <article class="workspace-panel">
                        <h2>Ready for expansion</h2>
                        <p>This split workspace can later host related access, members, and audit panels without changing the navigation model.</p>
                    </article>
                </div>

                <section class="workspace-panel workspace-panel--soft">
                    <h2>Select a partition</h2>
                    <p class="muted-text">Choose a node in the tree to inspect its information, update its description, or create a child partition.</p>
                </section>
            </div>
        }
        else if (isLoading)
        {
            <p class="muted-text">Loading partition...</p>
        }
        else if (selectedPartition is null)
        {
            <p class="muted-text">The selected partition could not be loaded.</p>
        }
        else
        {
            <div class="workspace-stack">
                <div class="workspace-panel-grid">
                    <article class="workspace-panel">
                        <h2>@selectedPartition.Name</h2>
                        <p>@(string.IsNullOrWhiteSpace(selectedPartition.Description) ? "No description informed." : selectedPartition.Description)</p>

                        <dl class="detail-list">
                            <div>
                                <dt>Guid</dt>
                                <dd>@selectedPartition.Guid</dd>
                            </div>
                            <div>
                                <dt>Parent</dt>
                                <dd>@(selectedPartition.ParentPartitionGuid?.ToString() ?? "Root partition")</dd>
                            </div>
                            <div>
                                <dt>Status</dt>
                                <dd>@(selectedPartition.IsActive ? "Active" : "Inactive")</dd>
                            </div>
                        </dl>
                    </article>

                    <article class="workspace-panel">
                        <h2>Create child partition</h2>

                        <EditForm Model="createModel" OnValidSubmit="CreateChildAsync" class="editor-form">
                            <DataAnnotationsValidator />

                            <label>
                                <span>Name</span>
                                <InputText @bind-Value="createModel.Name" class="text-field" />
                                <ValidationMessage For="() => createModel.Name" />
                            </label>

                            <label>
                                <span>Description</span>
                                <InputTextArea @bind-Value="createModel.Description" class="text-area" />
                            </label>

                            <div class="dialog-actions">
                                <button type="submit" class="primary-button" disabled="@isCreatingChild">
                                    @(isCreatingChild ? "Creating..." : "Create child")
                                </button>
                            </div>
                        </EditForm>
                    </article>
                </div>

                <section class="workspace-panel workspace-panel--soft">
                    <h2>Edit description</h2>

                    <EditForm Model="editModel" OnValidSubmit="SaveAsync" class="editor-form">
                        <DataAnnotationsValidator />

                        <label>
                            <span>Description</span>
                            <InputTextArea @bind-Value="editModel.Description" class="text-area" />
                        </label>

                        <div class="dialog-actions">
                            <button type="submit" class="primary-button" disabled="@isSaving">
                                @(isSaving ? "Saving..." : "Save changes")
                            </button>
                            <button type="button" class="ghost-button danger" @onclick="DeleteAsync" disabled="@isDeleting">
                                @(isDeleting ? "Deleting..." : "Delete partition")
                            </button>
                        </div>
                    </EditForm>
                </section>
            </div>
        }
    </DetailContent>
</SectionWorkspace>

@code {
    [Parameter]
    public Guid? PartitionGuid { get; set; }

    private Fargo.Sdk.Partitions.Partition? selectedPartition;
    private string? errorMessage;
    private bool isLoading;
    private bool isSaving;
    private bool isDeleting;
    private bool isCreatingChild;
    private PartitionCreateForm createModel = new();
    private PartitionEditForm editModel = new();

    protected override async Task OnParametersSetAsync()
    {
        await LoadSelectedPartitionAsync();
    }

    private async Task LoadSelectedPartitionAsync()
    {
        errorMessage = null;
        selectedPartition = null;
        createModel = new PartitionCreateForm();
        editModel = new PartitionEditForm();

        if (!PartitionGuid.HasValue)
        {
            return;
        }

        isLoading = true;

        try
        {
            selectedPartition = await Engine.Partitions.GetAsync(PartitionGuid.Value);
            editModel.Description = selectedPartition.Description;
        }
        catch (FargoSdkApiException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to load partition." : ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ReloadAsync()
    {
        await LoadSelectedPartitionAsync();
    }

    private async Task SaveAsync()
    {
        if (!PartitionGuid.HasValue || selectedPartition is null)
        {
            return;
        }

        isSaving = true;
        errorMessage = null;

        try
        {
            await selectedPartition.UpdateAsync(p => p.Description = editModel.Description ?? string.Empty);
            await LoadSelectedPartitionAsync();
        }
        catch (FargoSdkApiException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to save partition changes." : ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task CreateChildAsync()
    {
        if (!PartitionGuid.HasValue)
        {
            return;
        }

        isCreatingChild = true;
        errorMessage = null;

        try
        {
            var partition = await Engine.Partitions.CreateAsync(
                createModel.Name!,
                createModel.Description,
                PartitionGuid.Value);

            Navigation.NavigateTo($"/partitions/{partition.Guid}", forceLoad: true);
        }
        catch (FargoSdkApiException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to create child partition." : ex.Message;
        }
        finally
        {
            isCreatingChild = false;
        }
    }

    private async Task DeleteAsync()
    {
        if (!PartitionGuid.HasValue)
        {
            return;
        }

        isDeleting = true;
        errorMessage = null;

        try
        {
            await Engine.Partitions.DeleteAsync(PartitionGuid.Value);
            Navigation.NavigateTo("/partitions", forceLoad: true);
        }
        catch (FargoSdkApiException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to delete partition." : ex.Message;
        }
        finally
        {
            isDeleting = false;
        }
    }

    private sealed class PartitionCreateForm
    {
        [Required(ErrorMessage = "Name is required.")]
        public string? Name { get; set; }

        public string? Description { get; set; }
    }

    private sealed class PartitionEditForm
    {
        public string? Description { get; set; }
    }
}
