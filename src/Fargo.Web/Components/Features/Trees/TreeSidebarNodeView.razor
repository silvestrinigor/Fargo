<li>
    <div class="tree-node-row @(SelectedGuid == Node.EntityGuid ? "selected" : null)"
         @onclick="(() => OnSelect.InvokeAsync(Node))">

        <button type="button"
                class="tree-chevron @(Node.IsExpanded ? "open" : null)"
                style="@(Node.HasChildren ? null : "visibility:hidden")"
                @onclick="(() => OnToggle.InvokeAsync(Node))"
                @onclick:stopPropagation="true">
        </button>

        @if (Node.Icon is not null)
        {
            <img src="@Node.Icon" class="tree-node-icon" alt="" aria-hidden="true" />
        }

        <span class="tree-node-copy">
            <span class="tree-node-title">@Node.Title</span>
            @if (!string.IsNullOrWhiteSpace(Node.Subtitle))
            {
                <span class="tree-node-subtitle">@Node.Subtitle</span>
            }
        </span>

        <span class="tree-node-meta">
            @if (!Node.IsActive)
            {
                <span class="tree-badge">inactive</span>
            }
        </span>
    </div>

    @if (Node.IsExpanded)
    {
        if (Node.IsLoadingChildren)
        {
            <div class="tree-loading">Loading…</div>
        }
        else if (Node.Children.Count > 0)
        {
            <ul class="tree-list child-list">
                @foreach (var child in Node.Children.OrderBy(x => x.Title, StringComparer.OrdinalIgnoreCase))
                {
                    <TreeSidebarNodeView Node="child"
                                         SelectedGuid="SelectedGuid"
                                         OnToggle="OnToggle"
                                         OnSelect="OnSelect" />
                }
            </ul>
        }
    }
</li>

@code {
    [Parameter, EditorRequired]
    public required TreeSidebarNode Node { get; set; }

    [Parameter]
    public Guid? SelectedGuid { get; set; }

    [Parameter]
    public EventCallback<TreeSidebarNode> OnToggle { get; set; }

    [Parameter]
    public EventCallback<TreeSidebarNode> OnSelect { get; set; }
}
