@inject IEngine Engine

<div class="page-card">
    <div class="section-header">
        <h1>Users</h1>
        <button type="button" class="primary-button" @onclick="OpenCreate">New user</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="error-banner">@errorMessage</div>
    }

    @if (isLoading)
    {
        <p class="muted-text">Loading users...</p>
    }
    else if (FilteredUsers.Count == 0)
    {
        <p class="muted-text">No users found for the current filter.</p>
    }
    else
    {
        <div class="data-table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>NameId</th>
                        <th>First name</th>
                        <th>Last name</th>
                        <th>Description</th>
                        <th>Partitions</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in FilteredUsers)
                    {
                        <tr>
                            <td>@user.Nameid</td>
                            <td>@user.FirstName</td>
                            <td>@user.LastName</td>
                            <td>@user.Description</td>
                            <td>@user.PartitionAccesses.Count</td>
                            <td>@(user.IsActive ? "Active" : "Inactive")</td>
                            <td class="action-cell">
                                <button type="button" class="ghost-button small" @onclick="(() => OpenEdit(user))">Edit</button>
                                <button type="button" class="ghost-button small danger"
                                        @onclick="(() => OpenDelete(user))">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (editorOpen)
{
    <div class="overlay">
        <section class="dialog-card">
            <h2>@(isEditing ? "Edit user" : "Create user")</h2>

            <EditForm Model="editorModel" OnValidSubmit="SaveAsync" class="editor-form">
                <DataAnnotationsValidator />

                <label>
                    <span>NameId</span>
                    <InputText @bind-Value="editorModel.Nameid" class="text-field" />
                    <ValidationMessage For="() => editorModel.Nameid" />
                </label>

                <div class="toolbar-grid two-columns">
                    <label>
                        <span>First name</span>
                        <InputText @bind-Value="editorModel.FirstName" class="text-field" />
                    </label>

                    <label>
                        <span>Last name</span>
                        <InputText @bind-Value="editorModel.LastName" class="text-field" />
                    </label>
                </div>

                <label>
                    <span>Description</span>
                    <InputTextArea @bind-Value="editorModel.Description" class="text-area" />
                </label>

                @if (!isEditing)
                {
                    <label>
                        <span>Password</span>
                        <InputText @bind-Value="editorModel.Password" Type="password" class="text-field" />
                        <ValidationMessage For="() => editorModel.Password" />
                    </label>
                }

                <div class="dialog-actions">
                    <button type="button" class="ghost-button" @onclick="CloseEditor">Cancel</button>
                    <button type="submit" class="primary-button" disabled="@isSaving">
                        @(isSaving ? "Saving..." : "Save")
                    </button>
                </div>
            </EditForm>
        </section>
    </div>
}

@if (pendingDelete is not null)
{
    <div class="overlay">
        <section class="dialog-card">
            <h2>Delete user</h2>
            <p>Are you sure you want to delete <strong>@pendingDelete.Nameid</strong>?</p>

            <div class="dialog-actions">
                <button type="button" class="ghost-button" @onclick="CloseDelete">Cancel</button>
                <button type="button" class="primary-button danger" @onclick="DeleteAsync" disabled="@isDeleting">
                    @(isDeleting ? "Deleting..." : "Delete")
                </button>
            </div>
        </section>
    </div>
}

@code {
    private readonly List<Fargo.Sdk.Users.User> users = [];
    private string? errorMessage;
    private bool isLoading;
    private bool isSaving;
    private bool isDeleting;
    private bool editorOpen;
    private bool isEditing;
    private Guid? editingUserGuid;
    private Fargo.Sdk.Users.User? pendingDelete;
    private UserEditorModel editorModel = new();

    private IReadOnlyList<Fargo.Sdk.Users.User> FilteredUsers => users;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            users.Clear();
            users.AddRange(await Engine.Users.GetManyAsync());
        }
        catch (FargoSdkApiException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to load users." : ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenCreate()
    {
        isEditing = false;
        editingUserGuid = null;
        editorModel = new UserEditorModel();
        editorOpen = true;
    }

    private void OpenEdit(Fargo.Sdk.Users.User user)
    {
        isEditing = true;
        editingUserGuid = user.Guid;
        editorModel = new UserEditorModel
        {
            Nameid = user.Nameid,
            FirstName = user.FirstName,
            LastName = user.LastName,
            Description = user.Description
        };
        editorOpen = true;
    }

    private void CloseEditor()
    {
        if (!isSaving)
        {
            editorOpen = false;
        }
    }

    private async Task SaveAsync()
    {
        isSaving = true;
        errorMessage = null;

        try
        {
            if (isEditing && editingUserGuid.HasValue)
            {
                var user = users.FirstOrDefault(u => u.Guid == editingUserGuid.Value);
                if (user is not null)
                {
                    await user.UpdateAsync(u =>
                    {
                        u.Nameid = editorModel.Nameid!;
                        u.FirstName = string.IsNullOrWhiteSpace(editorModel.FirstName) ? null : editorModel.FirstName;
                        u.LastName = string.IsNullOrWhiteSpace(editorModel.LastName) ? null : editorModel.LastName;
                        u.Description = editorModel.Description ?? string.Empty;
                    });
                }
            }
            else
            {
                await Engine.Users.CreateAsync(
                    editorModel.Nameid!,
                    editorModel.Password!,
                    string.IsNullOrWhiteSpace(editorModel.FirstName) ? null : editorModel.FirstName,
                    string.IsNullOrWhiteSpace(editorModel.LastName) ? null : editorModel.LastName,
                    string.IsNullOrWhiteSpace(editorModel.Description) ? null : editorModel.Description);
            }

            editorOpen = false;
            await LoadUsersAsync();
        }
        catch (FargoSdkApiException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to save user." : ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private void OpenDelete(Fargo.Sdk.Users.User user)
    {
        pendingDelete = user;
    }

    private void CloseDelete()
    {
        if (!isDeleting)
        {
            pendingDelete = null;
        }
    }

    private async Task DeleteAsync()
    {
        if (pendingDelete is null)
        {
            return;
        }

        isDeleting = true;
        errorMessage = null;

        try
        {
            await Engine.Users.DeleteAsync(pendingDelete.Guid);
            pendingDelete = null;
            await LoadUsersAsync();
        }
        catch (FargoSdkApiException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to delete user." : ex.Message;
        }
        finally
        {
            isDeleting = false;
        }
    }

    private sealed class UserEditorModel
    {
        [Required(ErrorMessage = "NameId is required.")]
        public string? Nameid { get; set; }

        public string? FirstName { get; set; }

        public string? LastName { get; set; }

        public string? Description { get; set; }

        [Required(ErrorMessage = "Password is required when creating a user.")]
        public string? Password { get; set; }
    }
}
