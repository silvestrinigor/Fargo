@inject IEngine Engine
@inject NavigationManager Navigation

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="error-banner">@errorMessage</div>
}
else if (isLoading)
{
    <div class="muted-text">Loading users...</div>
}
else if (rootNodes.Count == 0)
{
    <div class="muted-text">No users available for the current user.</div>
}
else
{
    <ul class="tree-list">
        @foreach (var node in rootNodes.OrderBy(x => x.Title, StringComparer.OrdinalIgnoreCase))
        {
            <TreeSidebarNodeView Node="node" SelectedGuid="selectedUserGuid" OnToggle="ToggleAsync" OnSelect="Select" />
        }
    </ul>
}

@code {
    private readonly List<TreeSidebarNode> rootNodes = [];
    private bool isLoading = true;
    private string? errorMessage;
    private Guid? selectedUserGuid;

    protected override void OnInitialized()
    {
        selectedUserGuid = ReadSelectedGuid();
        _ = LoadAndRenderAsync();
    }

    protected override void OnParametersSet()
    {
        selectedUserGuid = ReadSelectedGuid();
    }

    private async Task LoadAndRenderAsync()
    {
        await LoadRootsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadRootsAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var users = await Engine.Users.GetManyAsync();
            rootNodes.Clear();
            rootNodes.AddRange(users.Select(TreeSidebarNode.FromUser));
        }
        catch (FargoSdkApiException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Failed to load users."
                : ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private Task ToggleAsync(TreeSidebarNode node)
    {
        node.IsExpanded = !node.IsExpanded;
        return Task.CompletedTask;
    }

    private void Select(TreeSidebarNode node)
    {
        selectedUserGuid = node.EntityGuid;
        Navigation.NavigateTo($"/entities/users/{node.EntityGuid}");
    }

    private Guid? ReadSelectedGuid()
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
        var parts = relative.Split('/', StringSplitOptions.RemoveEmptyEntries);

        // /entities/users/{guid}
        if (parts.Length >= 3
            && parts[0].Equals("entities", StringComparison.OrdinalIgnoreCase)
            && parts[1].Equals("users", StringComparison.OrdinalIgnoreCase)
            && Guid.TryParse(parts[2], out var guid))
        {
            return guid;
        }

        return null;
    }
}
