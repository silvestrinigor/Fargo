@inject IEngine Engine
@inject NavigationManager Navigation

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="error-banner">@errorMessage</div>
}
else if (isLoading)
{
    <div class="muted-text">Loading items...</div>
}
else if (nodes.Count == 0)
{
    <div class="muted-text">No items available for the current user.</div>
}
else
{
    <ul class="tree-list">
        @foreach (var node in nodes)
        {
            <TreeSidebarNodeView Node="node" SelectedGuid="selectedItemGuid" OnToggle="ToggleAsync" OnSelect="Select" />
        }
    </ul>
}

@code {
    private readonly List<TreeSidebarNode> nodes = [];
    private bool isLoading = true;
    private string? errorMessage;
    private Guid? selectedItemGuid;

    protected override void OnInitialized()
    {
        selectedItemGuid = ReadSelectedGuid();
        _ = LoadAndRenderAsync();
    }

    protected override void OnParametersSet()
    {
        selectedItemGuid = ReadSelectedGuid();
    }

    private async Task LoadAndRenderAsync()
    {
        await LoadAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var items = await Engine.Items.GetManyAsync();
            nodes.Clear();
            nodes.AddRange(items.Select(i => TreeSidebarNode.FromItem(i)));
        }
        catch (FargoSdkApiException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Failed to load items."
                : ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private Task ToggleAsync(TreeSidebarNode node)
    {
        node.IsExpanded = !node.IsExpanded;
        return Task.CompletedTask;
    }

    private void Select(TreeSidebarNode node)
    {
        selectedItemGuid = node.EntityGuid;
        Navigation.NavigateTo($"/entities/items/{node.EntityGuid}");
    }

    private Guid? ReadSelectedGuid()
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
        var parts = relative.Split('/', StringSplitOptions.RemoveEmptyEntries);

        // /entities/items/{guid}
        if (parts.Length >= 3
            && parts[0].Equals("entities", StringComparison.OrdinalIgnoreCase)
            && parts[1].Equals("items", StringComparison.OrdinalIgnoreCase)
            && Guid.TryParse(parts[2], out var guid))
        {
            return guid;
        }

        return null;
    }
}
