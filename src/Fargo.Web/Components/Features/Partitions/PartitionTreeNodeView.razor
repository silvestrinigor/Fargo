@using Fargo.Web.Features.Partitions

<li>
    <div class="tree-node-row @(SelectedGuid == Node.Guid ? "selected" : null)">
        <button type="button" class="tree-toggle" @onclick="(() => OnToggle.InvokeAsync(Node))">
            @(Node.IsExpanded ? "−" : "+")
        </button>

        <button type="button" class="tree-node-button" @onclick="(() => OnSelect.InvokeAsync(Node.Guid))">
            <span>@Node.Name</span>
            @if (!Node.IsActive)
            {
                <span class="tree-badge">inactive</span>
            }
        </button>
    </div>

    @if (Node.IsExpanded)
    {
        if (Node.IsLoadingChildren)
        {
            <div class="tree-loading">Loading…</div>
        }
        else if (Node.Children.Count > 0)
        {
            <ul class="tree-list child-list">
                @foreach (var child in Node.Children.OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase))
                {
                    <PartitionTreeNodeView Node="child" SelectedGuid="SelectedGuid" OnToggle="OnToggle" OnSelect="OnSelect" />
                }
            </ul>
        }
    }
</li>

@code {
    [Parameter, EditorRequired]
    public required PartitionTreeNode Node { get; set; }

    [Parameter]
    public Guid? SelectedGuid { get; set; }

    [Parameter]
    public EventCallback<PartitionTreeNode> OnToggle { get; set; }

    [Parameter]
    public EventCallback<Guid> OnSelect { get; set; }
}
