@inject IEngine Engine
@inject NavigationManager Navigation

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="error-banner">@errorMessage</div>
}
else if (isLoading)
{
    <div class="muted-text">Loading partition tree...</div>
}
else if (rootNodes.Count == 0)
{
    <div class="muted-text">No root partitions available for the current user.</div>
}
else
{
    <ul class="tree-list">
        @foreach (var node in rootNodes.OrderBy(x => x.Title, StringComparer.OrdinalIgnoreCase))
        {
            <TreeSidebarNodeView Node="node" SelectedGuid="selectedPartitionGuid" OnToggle="ToggleAsync" OnSelect="Select"
                                 OnDragStart="StartDrag" OnDrop="DropAsync" />
        }
    </ul>
}

@code {
    private readonly List<TreeSidebarNode> rootNodes = [];
    private bool isLoading = true;
    private string? errorMessage;
    private Guid? selectedPartitionGuid;
    private TreeSidebarNode? _dragging;

    protected override void OnInitialized()
    {
        selectedPartitionGuid = ReadSelectedGuid();
        _ = LoadAndRenderAsync();
    }

    protected override void OnParametersSet()
    {
        selectedPartitionGuid = ReadSelectedGuid();
    }

    private async Task LoadAndRenderAsync()
    {
        await LoadRootsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadRootsAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var roots = await Engine.Partitions.GetManyAsync(rootOnly: true);
            rootNodes.Clear();
            rootNodes.AddRange(roots.Select(TreeSidebarNode.FromPartition));
        }
        catch (FargoSdkApiException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Failed to load partitions."
                : ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ToggleAsync(TreeSidebarNode node)
    {
        node.IsExpanded = !node.IsExpanded;

        if (!node.IsExpanded || node.ChildrenLoaded || !node.HasChildren)
        {
            return;
        }

        node.IsLoadingChildren = true;
        errorMessage = null;

        try
        {
            var children = await Engine.Partitions.GetManyAsync(node.EntityGuid);
            node.Children.Clear();
            node.Children.AddRange(children.Select(TreeSidebarNode.FromPartition));
            node.ChildrenLoaded = true;

            if (node.Children.Count == 0)
            {
                node.HasChildren = false;
            }
        }
        catch (FargoSdkApiException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Failed to load child partitions."
                : ex.Message;
        }
        finally
        {
            node.IsLoadingChildren = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void Select(TreeSidebarNode node)
    {
        selectedPartitionGuid = node.EntityGuid;
        Navigation.NavigateTo($"/entities/partitions/{node.EntityGuid}");
    }

    private Guid? ReadSelectedGuid()
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
        var parts = relative.Split('/', StringSplitOptions.RemoveEmptyEntries);

        // /entities/partitions/{guid}
        if (parts.Length >= 3
            && parts[0].Equals("entities", StringComparison.OrdinalIgnoreCase)
            && parts[1].Equals("partitions", StringComparison.OrdinalIgnoreCase)
            && Guid.TryParse(parts[2], out var guid))
        {
            return guid;
        }

        return null;
    }

    // ── Drag and drop ────────────────────────────────────────────────────────

    private void StartDrag(TreeSidebarNode node) => _dragging = node;

    private async Task DropAsync(TreeSidebarNode target)
    {
        var source = _dragging;
        _dragging = null;

        if (source is null || source.EntityGuid == target.EntityGuid) return;

        errorMessage = null;

        try
        {
            var partition = await Engine.Partitions.GetAsync(source.EntityGuid);
            var result = await partition.MoveAsync(target.EntityGuid);

            if (!result.IsSuccess)
                errorMessage = result.Error?.Detail ?? "Failed to move partition.";
            else
                NotifyMoved(source.EntityGuid, target.EntityGuid);
        }
        catch (FargoSdkApiException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to move partition." : ex.Message;
        }
    }

    // ── Tree helpers ─────────────────────────────────────────────────────────

    private (List<TreeSidebarNode> list, TreeSidebarNode node)? FindInList(Guid guid, List<TreeSidebarNode> nodes)
    {
        foreach (var node in nodes)
        {
            if (node.EntityGuid == guid) return (nodes, node);
            var found = FindInList(guid, node.Children);
            if (found is not null) return found;
        }
        return null;
    }

    // ── Public notifications called by Entities.razor ────────────────────────

    public void NotifyUpdated(Guid guid, string name, bool isActive)
    {
        var result = FindInList(guid, rootNodes);
        if (result is { } found)
        {
            found.node.Title = name;
            found.node.IsActive = isActive;
            StateHasChanged();
        }
    }

    public void NotifyCreated(Guid guid, string name, bool isActive, Guid? parentGuid)
    {
        var newNode = new TreeSidebarNode
        {
            EntityGuid = guid,
            Title = name,
            Icon = "partition.svg",
            IsActive = isActive,
            HasChildren = false
        };

        if (parentGuid is null)
        {
            rootNodes.Add(newNode);
        }
        else
        {
            var parentResult = FindInList(parentGuid.Value, rootNodes);
            if (parentResult is { } found)
            {
                if (found.node.ChildrenLoaded)
                    found.node.Children.Add(newNode);
                found.node.HasChildren = true;
            }
        }

        StateHasChanged();
    }

    public void NotifyDeleted(Guid guid)
    {
        var result = FindInList(guid, rootNodes);
        if (result is { } found)
        {
            found.list.Remove(found.node);
            StateHasChanged();
        }
    }

    public void NotifyMoved(Guid guid, Guid newParentGuid)
    {
        var sourceResult = FindInList(guid, rootNodes);
        if (sourceResult is null) return;

        var (sourceList, sourceNode) = sourceResult.Value;
        sourceList.Remove(sourceNode);

        var targetResult = FindInList(newParentGuid, rootNodes);
        if (targetResult is { } target)
        {
            if (target.node.ChildrenLoaded)
                target.node.Children.Add(sourceNode);
            target.node.HasChildren = true;
        }

        StateHasChanged();
    }
}
