@inject IEngine Engine
@inject NavigationManager Navigation

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="error-banner">@errorMessage</div>
}
else if (isLoading)
{
    <div class="muted-text">Loading partition tree...</div>
}
else if (rootNodes.Count == 0)
{
    <div class="muted-text">No root partitions available for the current user.</div>
}
else
{
    <ul class="tree-list">
        @foreach (var node in rootNodes.OrderBy(x => x.Title, StringComparer.OrdinalIgnoreCase))
        {
            <TreeSidebarNodeView Node="node" SelectedGuid="selectedPartitionGuid" OnToggle="ToggleAsync" OnSelect="Select" />
        }
    </ul>
}

@code {
    private readonly List<TreeSidebarNode> rootNodes = [];
    private bool isLoading = true;
    private string? errorMessage;
    private Guid? selectedPartitionGuid;

    protected override void OnInitialized()
    {
        selectedPartitionGuid = ReadSelectedGuid();
        _ = LoadAndRenderAsync();
    }

    protected override void OnParametersSet()
    {
        selectedPartitionGuid = ReadSelectedGuid();
    }

    private async Task LoadAndRenderAsync()
    {
        await LoadRootsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadRootsAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var roots = await Engine.Partitions.GetManyAsync(rootOnly: true);
            rootNodes.Clear();
            rootNodes.AddRange(roots.Select(TreeSidebarNode.FromPartition));
        }
        catch (FargoSdkApiException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Failed to load partitions."
                : ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ToggleAsync(TreeSidebarNode node)
    {
        node.IsExpanded = !node.IsExpanded;

        if (!node.IsExpanded || node.ChildrenLoaded || !node.HasChildren)
        {
            return;
        }

        node.IsLoadingChildren = true;
        errorMessage = null;

        try
        {
            var children = await Engine.Partitions.GetManyAsync(node.EntityGuid);
            node.Children.Clear();
            node.Children.AddRange(children.Select(TreeSidebarNode.FromPartition));
            node.ChildrenLoaded = true;

            if (node.Children.Count == 0)
            {
                node.HasChildren = false;
            }
        }
        catch (FargoSdkApiException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Failed to load child partitions."
                : ex.Message;
        }
        finally
        {
            node.IsLoadingChildren = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void Select(TreeSidebarNode node)
    {
        selectedPartitionGuid = node.EntityGuid;
        Navigation.NavigateTo($"/entities/partitions/{node.EntityGuid}");
    }

    private Guid? ReadSelectedGuid()
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
        var parts = relative.Split('/', StringSplitOptions.RemoveEmptyEntries);

        // /entities/partitions/{guid}
        if (parts.Length >= 3
            && parts[0].Equals("entities", StringComparison.OrdinalIgnoreCase)
            && parts[1].Equals("partitions", StringComparison.OrdinalIgnoreCase)
            && Guid.TryParse(parts[2], out var guid))
        {
            return guid;
        }

        return null;
    }
}
