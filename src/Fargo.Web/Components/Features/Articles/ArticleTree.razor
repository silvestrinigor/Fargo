@inject IEngine Engine
@inject NavigationManager Navigation

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="error-banner">@errorMessage</div>
}
else if (isLoading)
{
    <div class="muted-text">Loading article tree...</div>
}
else if (rootNodes.Count == 0)
{
    <div class="muted-text">No root articles available for the current user.</div>
}
else
{
    <ul class="tree-list">
        @foreach (var node in rootNodes.OrderBy(x => x.Title, StringComparer.OrdinalIgnoreCase))
        {
            <TreeSidebarNodeView Node="node" SelectedGuid="selectedArticleGuid" OnToggle="ToggleAsync" OnSelect="Select" />
        }
    </ul>
}

@code {
    private readonly List<TreeSidebarNode> rootNodes = [];
    private bool isLoading = true;
    private string? errorMessage;
    private Guid? selectedArticleGuid;

    protected override async Task OnInitializedAsync()
    {
        selectedArticleGuid = ReadSelectedArticleGuid();
        await LoadRootsAsync();
    }

    protected override void OnParametersSet()
    {
        selectedArticleGuid = ReadSelectedArticleGuid();
    }

    private async Task LoadRootsAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var articles = await Engine.Articles.GetManyAsync();
            rootNodes.Clear();
            rootNodes.AddRange(articles.Select(TreeSidebarNode.FromArticle));
        }
        catch (FargoSdkApiException ex)
        {
            errorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Failed to load articles."
                : ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private Task ToggleAsync(TreeSidebarNode node)
    {
        node.IsExpanded = !node.IsExpanded;
        return Task.CompletedTask;
    }

    private void Select(TreeSidebarNode node)
    {
        selectedArticleGuid = node.EntityGuid;
        Navigation.NavigateTo($"/articles/{node.EntityGuid}{BuildQueryString(node)}");
    }

    private static string BuildQueryString(TreeSidebarNode node)
    {
        var queryParts = new List<string>
        {
            $"title={Uri.EscapeDataString(node.Title)}",
            $"active={node.IsActive.ToString().ToLowerInvariant()}"
        };

        if (!string.IsNullOrWhiteSpace(node.Subtitle))
        {
            queryParts.Add($"subtitle={Uri.EscapeDataString(node.Subtitle)}");
        }

        return $"?{string.Join("&", queryParts)}";
    }

    private Guid? ReadSelectedArticleGuid()
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
        var parts = relative.Split('/', StringSplitOptions.RemoveEmptyEntries);

        if (parts.Length >= 2
            && parts[0].Equals("articles", StringComparison.OrdinalIgnoreCase)
            && Guid.TryParse(parts[1], out var selectedArticleGuid))
        {
            return selectedArticleGuid;
        }

        return null;
    }
}
