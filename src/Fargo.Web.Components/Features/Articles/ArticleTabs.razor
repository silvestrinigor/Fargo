@using System.ComponentModel.DataAnnotations
@using Fargo.Sdk
@using Fargo.Sdk.Articles
@using Fargo.Sdk.Authentication
@using Fargo.Sdk.Contracts
@using Microsoft.AspNetCore.Components.Forms
@inject IArticleHttpClient Articles
@inject IJSRuntime JS
@inject NavigationManager Navigation

@if (_load.IsBusy)
{
    <p class="muted-text">Loading...</p>
}
else if (!string.IsNullOrWhiteSpace(_load.ErrorMessage))
{
    <div class="error-banner">@_load.ErrorMessage</div>
}
else if (_article is null)
{
    <p class="muted-text">Article could not be loaded.</p>
}
else
{
    <div class="workspace-stack">

        <section class="workspace-panel">
            <EditForm Model="_edit" OnValidSubmit="SaveAsync" class="@("editor-form" + (IsReadOnly ? " readonly-form" : ""))">
                <DataAnnotationsValidator />
                @if (!string.IsNullOrWhiteSpace(_save.ErrorMessage))
                {
                    <div class="error-banner">@_save.ErrorMessage</div>
                }

                <h3>Info</h3>

                <label>
                    <span>Name</span>
                    <InputText @bind-Value="_edit.Name" class="text-field" disabled="@IsReadOnly" />
                    <ValidationMessage For="() => _edit.Name" />
                </label>
                <label>
                    <span>Description</span>
                    <InputTextArea @bind-Value="_edit.Description" class="text-area" disabled="@IsReadOnly" />
                </label>

                <h3>Metrics</h3>

                <label>
                    <span>Mass</span>
                    <div class="metric-input">
                        <InputNumber @bind-Value="_edit.MassValue" class="text-field" placeholder="optional" disabled="@IsReadOnly" />
                        <select value="@_edit.MassUnit" @onchange="OnMassUnit" class="select-field" disabled="@IsReadOnly">
                            <option value="g">g</option>
                            <option value="kg">kg</option>
                            <option value="mg">mg</option>
                            <option value="lb">lb</option>
                            <option value="oz">oz</option>
                        </select>
                    </div>
                </label>
                <label>
                    <span>Length X</span>
                    <div class="metric-input">
                        <InputNumber @bind-Value="_edit.LengthXValue" class="text-field" placeholder="optional" disabled="@IsReadOnly" />
                        <select value="@_edit.LengthXUnit" @onchange="OnLengthXUnit" class="select-field" disabled="@IsReadOnly">
                            @foreach (var u in LengthUnits) { <option value="@u">@u</option> }
                        </select>
                    </div>
                </label>
                <label>
                    <span>Length Y</span>
                    <div class="metric-input">
                        <InputNumber @bind-Value="_edit.LengthYValue" class="text-field" placeholder="optional" disabled="@IsReadOnly" />
                        <select value="@_edit.LengthYUnit" @onchange="OnLengthYUnit" class="select-field" disabled="@IsReadOnly">
                            @foreach (var u in LengthUnits) { <option value="@u">@u</option> }
                        </select>
                    </div>
                </label>
                <label>
                    <span>Length Z</span>
                    <div class="metric-input">
                        <InputNumber @bind-Value="_edit.LengthZValue" class="text-field" placeholder="optional" disabled="@IsReadOnly" />
                        <select value="@_edit.LengthZUnit" @onchange="OnLengthZUnit" class="select-field" disabled="@IsReadOnly">
                            @foreach (var u in LengthUnits) { <option value="@u">@u</option> }
                        </select>
                    </div>
                </label>

                <dl class="detail-list detail-list--inline">
                    <div>
                        <dt>Last edited by</dt>
                        <dd><EditedByLabel EditedByGuid="_article!.EditedByGuid" /></dd>
                    </div>
                </dl>

                @if (!IsReadOnly)
                {
                    <div class="dialog-actions">
                        <button type="button" class="ghost-button danger" @onclick="OpenDelete" disabled="@_save.IsBusy">Delete</button>
                        <button type="submit" class="primary-button" disabled="@(!IsDirty || _save.IsBusy)">
                            @(_save.IsBusy ? "Saving..." : "Save")
                        </button>
                    </div>
                }
            </EditForm>
        </section>

        <section class="workspace-panel">
            <h3>Barcodes</h3>
            <div class="barcode-section">
                @if (!string.IsNullOrEmpty(_barcodeError))
                {
                    <div class="error-banner">@_barcodeError</div>
                }
                @if (_barcodes is null)
                {
                    <p class="muted-text">Loading barcodes...</p>
                }
                else if (IsBarcodesEmpty(_barcodes))
                {
                    <p class="muted-text">No barcodes added yet.</p>
                }
                else
                {
                    <div class="barcode-list">
                        @foreach (var barcode in GetBarcodeResults(_barcodes))
                        {
                            <div class="barcode-card">
                                <div class="barcode-format-label">@barcode.Format</div>
                                <canvas id="barcode-@barcode.Format" class="barcode-canvas"></canvas>
                                @if (!IsReadOnly)
                                {
                                    <button type="button" class="ghost-button danger" @onclick="() => ClearBarcodeAsync(barcode.Format)" disabled="@_isRemovingBarcode">Remove</button>
                                }
                            </div>
                        }
                    </div>
                }
                @if (!IsReadOnly)
                {
                    <div class="barcode-add-form">
                        <input type="text" class="text-field" @bind="_newBarcodeCode" placeholder="Barcode code" />
                        <select class="select-field" @bind="_newBarcodeFormat">
                            @foreach (var fmt in Enum.GetValues<BarcodeFormat>())
                            {
                                <option value="@fmt">@fmt</option>
                            }
                        </select>
                        <button type="button" class="primary-button" @onclick="UpsertBarcodeAsync" disabled="@(_isAddingBarcode || string.IsNullOrWhiteSpace(_newBarcodeCode))">
                            @(_isAddingBarcode ? "Adding..." : "Add Barcode")
                        </button>
                    </div>
                }
            </div>
        </section>

    </div>
}

<ConfirmDialog IsOpen="_deleteOpen"
               Title="Delete article"
               ConfirmText="Delete"
               ConfirmClass="danger"
               IsBusy="_delete.IsBusy"
               OnConfirm="DeleteAsync"
               OnCancel="() => _deleteOpen = false">
    <p>Are you sure you want to delete <strong>@_article?.Name</strong>?</p>
    @if (!string.IsNullOrWhiteSpace(_delete.ErrorMessage))
    {
        <div class="error-banner">@_delete.ErrorMessage</div>
    }
</ConfirmDialog>

@code {
    [Parameter, EditorRequired] public Guid EntityGuid { get; set; }
    [Parameter] public DateTimeOffset? TemporalAsOf { get; set; }

    private static readonly string[] LengthUnits = ["mm", "cm", "m", "km", "in", "ft"];

    private ArticleInfo? _article;
    private readonly AsyncState _load = new();
    private readonly AsyncState _save = new();
    private readonly AsyncState _delete = new();
    private bool _deleteOpen;
    private EditModel _edit = new();

    private ArticleBarcodesInfo? _barcodes;
    private string? _barcodeError;
    private string _newBarcodeCode = string.Empty;
    private BarcodeFormat _newBarcodeFormat = BarcodeFormat.Ean13;
    private bool _isAddingBarcode;
    private bool _isRemovingBarcode;
    private bool _barcodesNeedRender;

    private string? _origName;
    private string? _origDescription;
    private double? _origMass;
    private double? _origX;
    private double? _origY;
    private double? _origZ;

    private bool IsReadOnly => TemporalAsOf.HasValue;

    private Guid? _loadedGuid;
    private DateTimeOffset? _loadedTemporal;

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedGuid != EntityGuid || _loadedTemporal != TemporalAsOf)
        {
            _loadedGuid = EntityGuid;
            _loadedTemporal = TemporalAsOf;
            await LoadAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_barcodesNeedRender)
        {
            _barcodesNeedRender = false;
            await RenderBarcodeCanvasesAsync();
        }
    }

    private bool IsDirty => _article is not null && (
        _edit.Name != _origName ||
        (_edit.Description ?? "") != (_origDescription ?? "") ||
        _edit.MassValue != _origMass ||
        _edit.MassUnit != (_article.Metrics?.Mass?.Unit ?? "g") ||
        _edit.LengthXValue != _origX ||
        _edit.LengthXUnit != (_article.Metrics?.LengthX?.Unit ?? "m") ||
        _edit.LengthYValue != _origY ||
        _edit.LengthYUnit != (_article.Metrics?.LengthY?.Unit ?? "m") ||
        _edit.LengthZValue != _origZ ||
        _edit.LengthZUnit != (_article.Metrics?.LengthZ?.Unit ?? "m"));

    private async Task LoadAsync()
    {
        _article = null;
        _edit = new EditModel();
        _barcodes = null;
        _barcodeError = null;

        await _load.RunAsync(async () =>
        {
            _article = (await Articles.GetAsync(EntityGuid, TemporalAsOf)).Unwrap("Failed to load article.");
            _edit.Name = _article.Name;
            _edit.Description = _article.Description;
            _edit.MassValue = _article.Metrics?.Mass?.Value;
            _edit.MassUnit = _article.Metrics?.Mass?.Unit ?? "g";
            _edit.LengthXValue = _article.Metrics?.LengthX?.Value;
            _edit.LengthXUnit = _article.Metrics?.LengthX?.Unit ?? "m";
            _edit.LengthYValue = _article.Metrics?.LengthY?.Value;
            _edit.LengthYUnit = _article.Metrics?.LengthY?.Unit ?? "m";
            _edit.LengthZValue = _article.Metrics?.LengthZ?.Value;
            _edit.LengthZUnit = _article.Metrics?.LengthZ?.Unit ?? "m";
            _origName = _article.Name;
            _origDescription = _article.Description;
            _origMass = _article.Metrics?.Mass?.Value;
            _origX = _article.Metrics?.LengthX?.Value;
            _origY = _article.Metrics?.LengthY?.Value;
            _origZ = _article.Metrics?.LengthZ?.Value;

            LoadBarcodes();
        }, "Failed to load article.");

        StateHasChanged();
    }

    private async Task SaveAsync()
    {
        if (_article is null) return;

        await _save.RunAsync(async () =>
        {
            var metrics = new ArticleMetricsInfo(
                _edit.MassValue is null ? null : new MassInfo(_edit.MassValue.Value, _edit.MassUnit),
                _edit.LengthXValue is null ? null : new LengthInfo(_edit.LengthXValue.Value, _edit.LengthXUnit),
                _edit.LengthYValue is null ? null : new LengthInfo(_edit.LengthYValue.Value, _edit.LengthYUnit),
                _edit.LengthZValue is null ? null : new LengthInfo(_edit.LengthZValue.Value, _edit.LengthZUnit));
            await UpdateArticleAsync(_article with
            {
                Name = _edit.Name!,
                Description = _edit.Description ?? string.Empty,
                Metrics = metrics
            });
            await LoadAsync();
        }, "Failed to save.");
    }

    private void LoadBarcodes()
    {
        _barcodeError = null;
        _barcodes = _article?.Barcodes ?? new ArticleBarcodesInfo();
        if (!IsBarcodesEmpty(_barcodes))
            _barcodesNeedRender = true;
    }

    private async Task RenderBarcodeCanvasesAsync()
    {
        if (_barcodes is null) return;
        foreach (var barcode in GetBarcodeResults(_barcodes))
        {
            var canvasId = $"barcode-{barcode.Format}";
            var bcid = GetBcid(barcode.Format);
            try
            {
                await JS.InvokeVoidAsync("fargoBarcode.render", canvasId, bcid, barcode.Code);
            }
            catch
            {
                // best-effort
            }
        }
    }

    private static string GetBcid(BarcodeFormat format) => format switch
    {
        BarcodeFormat.Ean13 => "ean13",
        BarcodeFormat.Ean8 => "ean8",
        BarcodeFormat.UpcA => "upca",
        BarcodeFormat.UpcE => "upce",
        BarcodeFormat.Code128 => "code128",
        BarcodeFormat.Code39 => "code39",
        BarcodeFormat.Itf14 => "itf14",
        BarcodeFormat.Gs1128 => "gs1-128",
        BarcodeFormat.QrCode => "qrcode",
        BarcodeFormat.DataMatrix => "datamatrix",
        _ => "code128"
    };

    private async Task UpsertBarcodeAsync()
    {
        if (_article is null || string.IsNullOrWhiteSpace(_newBarcodeCode)) return;

        _isAddingBarcode = true;
        _barcodeError = null;
        try
        {
            var updated = SetBarcode(_barcodes ?? new ArticleBarcodesInfo(), _newBarcodeFormat, _newBarcodeCode.Trim());
            await UpdateArticleAsync(_article with { Barcodes = updated });
            _article = _article with { Barcodes = updated };
            _newBarcodeCode = string.Empty;
            LoadBarcodes();
            StateHasChanged();
            await Task.Yield();
            await RenderBarcodeCanvasesAsync();
        }
        catch (FargoSdkApiException ex)
        {
            _barcodeError = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to add barcode." : ex.Message;
        }
        finally
        {
            _isAddingBarcode = false;
        }
    }

    private async Task ClearBarcodeAsync(BarcodeFormat barcodeFormat)
    {
        if (_article is null) return;

        _isRemovingBarcode = true;
        _barcodeError = null;
        try
        {
            var updated = RemoveBarcode(_barcodes ?? new ArticleBarcodesInfo(), barcodeFormat);
            await UpdateArticleAsync(_article with { Barcodes = updated });
            _article = _article with { Barcodes = updated };
            LoadBarcodes();
            StateHasChanged();
            await Task.Yield();
            await RenderBarcodeCanvasesAsync();
        }
        catch (FargoSdkApiException ex)
        {
            _barcodeError = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to remove barcode." : ex.Message;
        }
        finally
        {
            _isRemovingBarcode = false;
        }
    }

    private async Task UpdateArticleAsync(ArticleInfo article)
    {
        (await Articles.UpdateAsync(
            article.Guid,
            new ArticleUpdateRequest(
                article.Name,
                article.Description,
                article.Metrics,
                article.ShelfLife,
                article.Partitions,
                article.Barcodes,
                article.IsActive))).EnsureSuccess("Failed to update article.");
    }

    private static ArticleBarcodesInfo SetBarcode(ArticleBarcodesInfo barcodes, BarcodeFormat format, string code) => format switch
    {
        BarcodeFormat.Ean13 => barcodes with { Ean13 = code },
        BarcodeFormat.Ean8 => barcodes with { Ean8 = code },
        BarcodeFormat.UpcA => barcodes with { UpcA = code },
        BarcodeFormat.UpcE => barcodes with { UpcE = code },
        BarcodeFormat.Code128 => barcodes with { Code128 = code },
        BarcodeFormat.Code39 => barcodes with { Code39 = code },
        BarcodeFormat.Itf14 => barcodes with { Itf14 = code },
        BarcodeFormat.Gs1128 => barcodes with { Gs1128 = code },
        BarcodeFormat.QrCode => barcodes with { QrCode = code },
        BarcodeFormat.DataMatrix => barcodes with { DataMatrix = code },
        _ => barcodes
    };

    private static ArticleBarcodesInfo RemoveBarcode(ArticleBarcodesInfo barcodes, BarcodeFormat format) => format switch
    {
        BarcodeFormat.Ean13 => barcodes with { Ean13 = null },
        BarcodeFormat.Ean8 => barcodes with { Ean8 = null },
        BarcodeFormat.UpcA => barcodes with { UpcA = null },
        BarcodeFormat.UpcE => barcodes with { UpcE = null },
        BarcodeFormat.Code128 => barcodes with { Code128 = null },
        BarcodeFormat.Code39 => barcodes with { Code39 = null },
        BarcodeFormat.Itf14 => barcodes with { Itf14 = null },
        BarcodeFormat.Gs1128 => barcodes with { Gs1128 = null },
        BarcodeFormat.QrCode => barcodes with { QrCode = null },
        BarcodeFormat.DataMatrix => barcodes with { DataMatrix = null },
        _ => barcodes
    };

    private static bool IsBarcodesEmpty(ArticleBarcodesInfo barcodes)
        => GetBarcodeResults(barcodes).All(static barcode => string.IsNullOrWhiteSpace(barcode.Code));

    private static IEnumerable<BarcodeResult> GetBarcodeResults(ArticleBarcodesInfo barcodes)
    {
        if (!string.IsNullOrWhiteSpace(barcodes.Ean13)) yield return new(BarcodeFormat.Ean13, barcodes.Ean13);
        if (!string.IsNullOrWhiteSpace(barcodes.Ean8)) yield return new(BarcodeFormat.Ean8, barcodes.Ean8);
        if (!string.IsNullOrWhiteSpace(barcodes.UpcA)) yield return new(BarcodeFormat.UpcA, barcodes.UpcA);
        if (!string.IsNullOrWhiteSpace(barcodes.UpcE)) yield return new(BarcodeFormat.UpcE, barcodes.UpcE);
        if (!string.IsNullOrWhiteSpace(barcodes.Code128)) yield return new(BarcodeFormat.Code128, barcodes.Code128);
        if (!string.IsNullOrWhiteSpace(barcodes.Code39)) yield return new(BarcodeFormat.Code39, barcodes.Code39);
        if (!string.IsNullOrWhiteSpace(barcodes.Itf14)) yield return new(BarcodeFormat.Itf14, barcodes.Itf14);
        if (!string.IsNullOrWhiteSpace(barcodes.Gs1128)) yield return new(BarcodeFormat.Gs1128, barcodes.Gs1128);
        if (!string.IsNullOrWhiteSpace(barcodes.QrCode)) yield return new(BarcodeFormat.QrCode, barcodes.QrCode);
        if (!string.IsNullOrWhiteSpace(barcodes.DataMatrix)) yield return new(BarcodeFormat.DataMatrix, barcodes.DataMatrix);
    }

    private void OpenDelete()
    {
        _delete.Clear();
        _deleteOpen = true;
    }

    private async Task DeleteAsync()
    {
        var ok = await _delete.RunAsync(async () =>
        {
            (await Articles.DeleteAsync(EntityGuid)).EnsureSuccess("Failed to delete article.");
            Navigation.NavigateTo("/entities/articles");
        }, "Failed to delete.");

        if (ok) _deleteOpen = false;
    }

    private void OnMassUnit(ChangeEventArgs e) => _edit.MassUnit = e.Value?.ToString() ?? "g";
    private void OnLengthXUnit(ChangeEventArgs e) => _edit.LengthXUnit = e.Value?.ToString() ?? "m";
    private void OnLengthYUnit(ChangeEventArgs e) => _edit.LengthYUnit = e.Value?.ToString() ?? "m";
    private void OnLengthZUnit(ChangeEventArgs e) => _edit.LengthZUnit = e.Value?.ToString() ?? "m";

    private enum BarcodeFormat
    {
        Ean13,
        Ean8,
        UpcA,
        UpcE,
        Code128,
        Code39,
        Itf14,
        Gs1128,
        QrCode,
        DataMatrix
    }

    private sealed record BarcodeResult(BarcodeFormat Format, string Code);

    private sealed class EditModel
    {
        [Required(ErrorMessage = "Name is required.")]
        public string? Name { get; set; }
        public string? Description { get; set; }
        public double? MassValue { get; set; }
        public string MassUnit { get; set; } = "g";
        public double? LengthXValue { get; set; }
        public string LengthXUnit { get; set; } = "m";
        public double? LengthYValue { get; set; }
        public string LengthYUnit { get; set; } = "m";
        public double? LengthZValue { get; set; }
        public string LengthZUnit { get; set; } = "m";
    }
}
