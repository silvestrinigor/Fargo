@using Fargo.Api
@using Fargo.Api.Authentication
@using Fargo.Sdk.Contracts
@using Fargo.Web.Components.Shared

@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Navigation
@inject FargoSession FargoSession

<SessionBootstrapper />

@if (!FargoSession.IsReady)
{
    <div class="splash-screen">
        <h1>Fargo</h1>
        <p>Loading workspace...</p>
    </div>
}
else if (!FargoSession.IsAuthenticated || FargoSession.Authentication.IsExpired)
{
    <div class="splash-screen">
        <h1>Fargo</h1>
        <p>Redirecting to login...</p>
    </div>
}
else
{
    <div class="app-shell">
        <header class="app-header">
            <div class="app-header-side app-header-branding">
                <div class="app-brand">Fargo</div>
            </div>

            <nav class="app-nav" aria-label="Primary">
                <a class="@(IsActive("/entities") ? "nav-link active" : "nav-link")" href="/entities">Entities</a>
            </nav>

            <div class="app-header-side app-header-actions">
                <div class="user-menu">
                    @if (_userMenuOpen)
                    {
                        <div class="picker-backdrop" @onclick="CloseUserMenu"></div>
                    }
                    <button type="button"
                            class="user-avatar-btn @(_userMenuOpen ? "open" : null)"
                            @onclick="ToggleUserMenu"
                            aria-label="User menu"
                            aria-expanded="@_userMenuOpen">
                        <img src="_content/Fargo.Web.Components/user.svg" alt="" aria-hidden="true" />
                    </button>
                    @if (_userMenuOpen)
                    {
                        <div class="user-menu-dropdown" role="menu">
                            <div class="user-menu-header">
                                <span class="user-menu-name">@FargoSession.Authentication.Session.Nameid</span>
                            </div>
                            <div class="user-menu-divider"></div>
                            <a href="/settings" class="user-menu-item" role="menuitem" @onclick="CloseUserMenu">Settings</a>
                            <div class="user-menu-divider"></div>
                            <button type="button" class="user-menu-item user-menu-signout" role="menuitem" @onclick="LogoutAsync">Sign out</button>
                        </div>
                    }
                </div>
            </div>
        </header>

        <main class="app-main">
            @Body
        </main>
    </div>
}

@code {
    protected override void OnInitialized()
    {
        FargoSession.Changed += HandleSessionChanged;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (ShouldRedirectToLogin())
        {
            Navigation.NavigateTo("/login", replace: true);
        }
    }

    private bool _userMenuOpen;

    private void ToggleUserMenu() => _userMenuOpen = !_userMenuOpen;
    private void CloseUserMenu() => _userMenuOpen = false;

    private async Task LogoutAsync()
    {
        await FargoSession.Authentication.LogOutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private bool IsActive(string path)
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
        return relative.StartsWith(path.TrimStart('/'), StringComparison.OrdinalIgnoreCase);
    }

    private void HandleSessionChanged()
    {
        InvokeAsync(() =>
        {
            if (ShouldRedirectToLogin())
            {
                Navigation.NavigateTo("/login", replace: true);
            }
            else
            {
                StateHasChanged();
            }
        });
    }

    private bool ShouldRedirectToLogin() =>
        FargoSession.IsReady &&
        (!FargoSession.IsAuthenticated || FargoSession.Authentication.IsExpired) &&
        !Navigation.Uri.Contains("/login", StringComparison.OrdinalIgnoreCase);

    public void Dispose()
    {
        FargoSession.Changed -= HandleSessionChanged;
    }
}
