@using Fargo.Sdk.Events
@inject IAuthenticationService Auth
@inject IFargoEventHub Hub
@inject FargoSdkOptions Options
@inject FargoHubLifetimeService HubLifetime
@inject FargoSession FargoSession

@code {
    private bool attempted;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || attempted)
        {
            return;
        }

        attempted = true;

        try
        {
            var restored = await Auth.RestoreAsync();
            if (restored)
            {
                _ = Hub.ConnectAsync(Options.Server, () => Task.FromResult(Auth.Session.AccessToken));
            }
            FargoSession.MarkReady();
        }
        catch (InvalidOperationException)
        {
            attempted = false;
        }
        catch (JSDisconnectedException)
        {
            attempted = false;
        }
        catch
        {
            FargoSession.MarkReady();
        }
    }
}
