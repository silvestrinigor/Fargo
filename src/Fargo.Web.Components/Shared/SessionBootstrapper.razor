@using Fargo.Sdk
@inject IEngine Engine
@inject FargoSession FargoSession

@code {
    private bool attempted;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || attempted)
        {
            return;
        }

        attempted = true;

        try
        {
            await Engine.Authentication.RestoreAsync();
            FargoSession.MarkReady();
        }
        catch (InvalidOperationException)
        {
            attempted = false;
        }
        catch (JSDisconnectedException)
        {
            attempted = false;
        }
        catch
        {
            FargoSession.MarkReady();
        }
    }
}
