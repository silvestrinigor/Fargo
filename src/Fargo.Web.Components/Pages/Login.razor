@page "/login"
@layout LoginLayout
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Fargo.Sdk
@using Fargo.Sdk.Authentication
@using Fargo.Web.Components.Security
@inject IEngine Engine
@inject BrowserSdkSessionStore SessionStore
@inject FargoSession FargoSession
@inject NavigationManager Navigation

<PageTitle>Login | Fargo</PageTitle>

<div class="login-page">
    <section class="login-card">
        <h1>Sign in to Fargo</h1>
        <p class="muted-text">Enter your credentials to access the workspace.</p>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="error-banner">@errorMessage</div>
        }

        <EditForm Model="model" OnValidSubmit="HandleLoginAsync" class="editor-form">
            <DataAnnotationsValidator />

            <label>
                <span>NameId</span>
                <InputText @bind-Value="model.Nameid" class="text-field" />
                <ValidationMessage For="() => model.Nameid" />
            </label>

            <label>
                <span>Password</span>
                <InputText @bind-Value="model.Password" Type="password" class="text-field" />
                <ValidationMessage For="() => model.Password" />
            </label>

            <label class="checkbox-row">
                <InputCheckbox @bind-Value="model.RememberMe" />
                <span>Keep session on this browser</span>
            </label>

            <button type="submit" class="primary-button" disabled="@isSubmitting">
                @(isSubmitting ? "Signing in..." : "Sign in")
            </button>
        </EditForm>
    </section>
</div>

@code {
    private readonly LoginInputModel model = new();
    private bool isSubmitting;
    private string? errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || FargoSession.IsAuthenticated)
        {
            return;
        }

        try
        {
            var restored = await Engine.Authentication.RestoreAsync();

            if (restored)
            {
                Navigation.NavigateTo("/entities", replace: true);
            }
        }
        catch
        {
            FargoSession.MarkReady();
        }
    }

    private async Task HandleLoginAsync()
    {
        if (isSubmitting)
        {
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        try
        {
            SessionStore.RememberMe = model.RememberMe;
            await Engine.Authentication.LogInAsync(model.Nameid!, model.Password!);
            Navigation.NavigateTo("/entities", replace: true);
        }
        catch (InvalidCredentialsFargoSdkException)
        {
            errorMessage = "Unable to sign in with the provided credentials.";
        }
        catch (PasswordChangeRequiredFargoSdkException)
        {
            errorMessage = "You must change your password before signing in.";
        }
        catch (FargoSdkConnectionException ex)
        {
            errorMessage = ex.Message;
        }
        catch
        {
            errorMessage = "An unexpected error happened while trying to sign in.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class LoginInputModel
    {
        [Required(ErrorMessage = "NameId is required.")]
        public string? Nameid { get; set; }

        [Required(ErrorMessage = "Password is required.")]
        public string? Password { get; set; }

        public bool RememberMe { get; set; } = true;
    }
}
