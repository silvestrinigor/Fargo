@page "/entities/partitions"
@page "/entities/partitions/{EntityGuid:guid}"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using Fargo.Sdk
@using Fargo.Sdk.Partitions
@using Fargo.Sdk.Articles
@using Fargo.Sdk.Items
@using Fargo.Sdk.Users
@inject IEngine Engine
@inject NavigationManager Navigation

<PageTitle>Fargo · Partitions</PageTitle>

<EntitiesShell ActiveSection="partitions"
               SingularLabel="Partition"
               PartitionViewAvailable="true"
               PartitionView="_entityView"
               PartitionViewChanged="v => _entityView = v"
               OnNewClick="OpenCreate">
    <Explorer>
        @if (_entityView)
        {
            <PartitionAllEntitiesTree @ref="_allEntitiesTree" />
        }
        else
        {
            <PartitionTree @ref="_tree" />
        }
    </Explorer>
    <Detail>
        @if (!EntityGuid.HasValue)
        {
            <div class="detail-empty">
                <p class="muted-text">Select a partition to inspect its details and edit its description.</p>
            </div>
        }
        else if (_load.IsBusy)
        {
            <p class="muted-text">Loading...</p>
        }
        else if (!string.IsNullOrWhiteSpace(_load.ErrorMessage))
        {
            <div class="error-banner">@_load.ErrorMessage</div>
        }
        else if (_partition is null)
        {
            <p class="muted-text">Partition could not be loaded.</p>
        }
        else
        {
            <div class="workspace-stack">
                <section class="workspace-panel">
                    <EditForm Model="_edit" OnValidSubmit="SaveAsync" class="editor-form">
                        <DataAnnotationsValidator />
                        @if (!string.IsNullOrWhiteSpace(_save.ErrorMessage))
                        {
                            <div class="error-banner">@_save.ErrorMessage</div>
                        }
                        @if (_isGlobal)
                        {
                            <label>
                                <span>Name</span>
                                <input type="text" class="text-field" value="@_partition.Name" disabled />
                            </label>
                        }
                        else
                        {
                            <label>
                                <span>Name</span>
                                <InputText @bind-Value="_edit.Name" class="text-field" />
                                <ValidationMessage For="() => _edit.Name" />
                            </label>
                            <label>
                                <span>Parent partition</span>
                                <InputText @bind-Value="_edit.ParentGuid" class="text-field" placeholder="Partition GUID (leave blank for root)" />
                                <ValidationMessage For="() => _edit.ParentGuid" />
                            </label>
                        }
                        <label>
                            <span>Description</span>
                            <InputTextArea @bind-Value="_edit.Description" class="text-area" />
                        </label>
                        <label class="checkbox-row">
                            <InputCheckbox @bind-Value="_edit.IsActive" disabled="@_isGlobal" />
                            <span>Active</span>
                        </label>
                        <div class="dialog-actions">
                            <button type="button" class="ghost-button danger" @onclick="OpenDelete" disabled="@_save.IsBusy">Delete</button>
                            <button type="submit" class="primary-button" disabled="@(!IsDirty || _save.IsBusy)">
                                @(_save.IsBusy ? "Saving..." : "Save")
                            </button>
                        </div>
                    </EditForm>
                </section>

                <section class="workspace-panel">
                    <div class="editor-form">
                        <div class="section-header">
                            <span class="section-title">Entities in this partition</span>
                            <div class="section-actions">
                                <button type="button" class="ghost-button" @onclick="() => _addArticleOpen = true">+ Add Article</button>
                                <button type="button" class="ghost-button" @onclick="() => _addItemOpen = true">+ Add Item</button>
                                <button type="button" class="ghost-button" @onclick="() => _addUserOpen = true">+ Add User</button>
                            </div>
                        </div>

                        @if (_entityListLoading)
                        {
                            <p class="muted-text">Loading entities...</p>
                        }
                        else if (!string.IsNullOrWhiteSpace(_entityListError))
                        {
                            <div class="error-banner">@_entityListError</div>
                        }
                        else if (_entityItems.Count == 0)
                        {
                            <p class="muted-text">No entities in this partition.</p>
                        }
                        else
                        {
                            var pageItems = _entityItems
                                .Skip((_entityPage - 1) * _entityPageSize)
                                .Take(_entityPageSize)
                                .ToList();

                            <div class="data-table-wrapper">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>Type</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in pageItems)
                                        {
                                            <tr>
                                                <td>
                                                    <span class="entity-row-name">
                                                        <img src="@row.Icon" alt="@row.TypeLabel" class="tree-icon-sm" />
                                                        @row.Title
                                                    </span>
                                                </td>
                                                <td class="muted-text">@row.TypeLabel</td>
                                                <td>
                                                    <button type="button" class="ghost-button danger" @onclick="() => RemoveEntityAsync(row)">Remove</button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            @if (_entityTotalPages > 1)
                            {
                                <div class="pagination-bar">
                                    <button type="button" class="ghost-button" disabled="@(_entityPage <= 1)" @onclick="() => _entityPage--">&#8592;</button>
                                    <span class="muted-text">@_entityPage / @_entityTotalPages</span>
                                    <button type="button" class="ghost-button" disabled="@(_entityPage >= _entityTotalPages)" @onclick="() => _entityPage++">&#8594;</button>
                                </div>
                            }
                        }
                    </div>
                </section>
            </div>
        }
    </Detail>
</EntitiesShell>

<EditorDialog TModel="CreateForm"
              IsOpen="_createOpen"
              Title="New Partition"
              Model="_createForm"
              IsBusy="_create.IsBusy"
              ErrorMessage="@_create.ErrorMessage"
              OnSubmit="CreateAsync"
              OnCancel="() => _createOpen = false">
    <label>
        <span>Name</span>
        <InputText @bind-Value="context.Name" class="text-field" />
        <ValidationMessage For="() => context.Name" />
    </label>
</EditorDialog>

<ConfirmDialog IsOpen="_deleteOpen"
               Title="Delete partition"
               ConfirmText="Delete"
               ConfirmClass="danger"
               IsBusy="_delete.IsBusy"
               OnConfirm="DeleteAsync"
               OnCancel="() => _deleteOpen = false">
    <p>Are you sure you want to delete <strong>@_partition?.Name</strong>?</p>
    @if (!string.IsNullOrWhiteSpace(_delete.ErrorMessage))
    {
        <div class="error-banner">@_delete.ErrorMessage</div>
    }
</ConfirmDialog>

<EntityPickerDialog TEntity="Article"
                    IsOpen="_addArticleOpen"
                    Title="Add Article"
                    Loader="s => Engine.Articles.GetManyAsync(search: s)"
                    ColumnHeaders='["Name"]'
                    OnSelected="AddArticleAsync"
                    OnCancel="() => _addArticleOpen = false">
    <RowTemplate Context="a">
        <td>@a.Name</td>
    </RowTemplate>
</EntityPickerDialog>

<EntityPickerDialog TEntity="Item"
                    IsOpen="_addItemOpen"
                    Title="Add Item"
                    Loader="async _ => (IReadOnlyCollection<Item>)await Engine.Items.GetManyAsync()"
                    ColumnHeaders='["Item", "Article"]'
                    OnSelected="AddItemAsync"
                    OnCancel="() => _addItemOpen = false">
    <RowTemplate Context="i">
        <td>@i.Guid.ToString("N")[..8]</td>
        <td>@i.ArticleGuid.ToString("N")[..8]</td>
    </RowTemplate>
</EntityPickerDialog>

<EntityPickerDialog TEntity="User"
                    IsOpen="_addUserOpen"
                    Title="Add User"
                    Loader="s => Engine.Users.GetManyAsync(search: s)"
                    ColumnHeaders='["Name"]'
                    OnSelected="AddUserAsync"
                    OnCancel="() => _addUserOpen = false">
    <RowTemplate Context="u">
        <td>@u.Nameid</td>
    </RowTemplate>
</EntityPickerDialog>

@code {
    [Parameter] public Guid? EntityGuid { get; set; }

    private PartitionTree? _tree;
    private PartitionAllEntitiesTree? _allEntitiesTree;
    private bool _entityView;

    private Partition? _partition;
    private Guid? _loadedGuid;
    private EditModel _edit = new();
    private string? _origName;
    private string? _origDescription;
    private string? _origParent;
    private bool _origIsActive;

    private readonly AsyncState _load = new();
    private readonly AsyncState _save = new();
    private readonly AsyncState _delete = new();
    private readonly AsyncState _create = new();

    private bool _createOpen;
    private bool _deleteOpen;
    private CreateForm _createForm = new();

    // ── Entity list state ────────────────────────────────────────────────────

    private readonly List<PartitionEntityRow> _entityItems = [];
    private bool _entityListLoading;
    private string? _entityListError;
    private int _entityPage = 1;
    private const int _entityPageSize = 20;
    private int _entityTotalPages => (int)Math.Ceiling(_entityItems.Count / (double)_entityPageSize);

    private bool _addArticleOpen;
    private bool _addItemOpen;
    private bool _addUserOpen;

    private bool _isGlobal => _partition?.ParentPartitionGuid is null;

    private bool IsDirty => _partition is not null && (
        (!_isGlobal && _edit.Name != _origName) ||
        (_edit.Description ?? "") != (_origDescription ?? "") ||
        _edit.IsActive != _origIsActive ||
        (!_isGlobal && (_edit.ParentGuid ?? "") != (_origParent ?? "")));

    protected override async Task OnParametersSetAsync()
    {
        if (EntityGuid != _loadedGuid)
        {
            _loadedGuid = EntityGuid;
            if (EntityGuid.HasValue)
            {
                await LoadAsync();
            }
            else
            {
                _partition = null;
                _entityItems.Clear();
            }
        }
    }

    private async Task LoadAsync()
    {
        _partition = null;
        _edit = new EditModel();
        _entityItems.Clear();
        _entityPage = 1;

        await _load.RunAsync(async () =>
        {
            _partition = await Engine.Partitions.GetAsync(EntityGuid!.Value);
            _edit.Name = _partition.Name;
            _edit.Description = _partition.Description;
            _edit.ParentGuid = _partition.ParentPartitionGuid?.ToString();
            _edit.IsActive = _partition.IsActive;
            _origName = _partition.Name;
            _origDescription = _partition.Description;
            _origParent = _partition.ParentPartitionGuid?.ToString();
            _origIsActive = _partition.IsActive;
        }, "Failed to load partition.");

        if (_partition is not null)
            await LoadEntityListAsync(EntityGuid!.Value);
    }

    private async Task LoadEntityListAsync(Guid partitionGuid)
    {
        _entityListLoading = true;
        _entityListError = null;
        _entityItems.Clear();
        _entityPage = 1;
        StateHasChanged();

        try
        {
            var articles = await Engine.Articles.GetManyAsync(partitionGuid: partitionGuid, limit: 200);
            var items = await Engine.Items.GetManyAsync(partitionGuid: partitionGuid, limit: 200);
            var users = await Engine.Users.GetManyAsync(partitionGuid: partitionGuid, limit: 200);

            _entityItems.AddRange(articles.Select(a => new PartitionEntityRow(
                a.Guid, a.Name, "article", TreeSidebarNode.Icons.Article, EntityType.Article)));
            _entityItems.AddRange(items.Select(i => new PartitionEntityRow(
                i.Guid, i.Guid.ToString("N")[..8], "item", TreeSidebarNode.Icons.Item, EntityType.Item)));
            _entityItems.AddRange(users.Select(u => new PartitionEntityRow(
                u.Guid, u.Nameid, "user", TreeSidebarNode.Icons.User, EntityType.User)));

            _entityItems.Sort((a, b) => string.Compare(a.Title, b.Title, StringComparison.OrdinalIgnoreCase));
        }
        catch (FargoSdkApiException ex)
        {
            _entityListError = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to load entities." : ex.Message;
        }
        finally
        {
            _entityListLoading = false;
        }
    }

    private async Task RemoveEntityAsync(PartitionEntityRow row)
    {
        if (!EntityGuid.HasValue) return;

        try
        {
            FargoSdkResponse<EmptyResult> result;

            switch (row.Type)
            {
                case EntityType.Article:
                    var article = await Engine.Articles.GetAsync(row.EntityGuid);
                    result = await article.RemovePartitionAsync(EntityGuid.Value);
                    break;
                case EntityType.Item:
                    var item = await Engine.Items.GetAsync(row.EntityGuid);
                    result = await item.RemovePartitionAsync(EntityGuid.Value);
                    break;
                case EntityType.User:
                    var user = await Engine.Users.GetAsync(row.EntityGuid);
                    result = await user.RemovePartitionAsync(EntityGuid.Value);
                    break;
                default:
                    return;
            }

            if (result.IsSuccess)
            {
                _entityItems.Remove(row);
                if (_entityPage > _entityTotalPages && _entityPage > 1)
                    _entityPage--;
            }
            else
            {
                _entityListError = result.Error?.Detail ?? "Failed to remove entity.";
            }
        }
        catch (FargoSdkApiException ex)
        {
            _entityListError = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to remove entity." : ex.Message;
        }
    }

    private async Task AddArticleAsync(Article article)
    {
        _addArticleOpen = false;
        if (!EntityGuid.HasValue) return;

        try
        {
            var result = await article.AddPartitionAsync(EntityGuid.Value);
            if (result.IsSuccess)
            {
                if (!_entityItems.Any(r => r.EntityGuid == article.Guid))
                {
                    _entityItems.Add(new PartitionEntityRow(article.Guid, article.Name, "article", TreeSidebarNode.Icons.Article, EntityType.Article));
                    _entityItems.Sort((a, b) => string.Compare(a.Title, b.Title, StringComparison.OrdinalIgnoreCase));
                }
            }
            else
            {
                _entityListError = result.Error?.Detail ?? "Failed to add article.";
            }
        }
        catch (FargoSdkApiException ex)
        {
            _entityListError = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to add article." : ex.Message;
        }
    }

    private async Task AddItemAsync(Item item)
    {
        _addItemOpen = false;
        if (!EntityGuid.HasValue) return;

        try
        {
            var result = await item.AddPartitionAsync(EntityGuid.Value);
            if (result.IsSuccess)
            {
                if (!_entityItems.Any(r => r.EntityGuid == item.Guid))
                {
                    _entityItems.Add(new PartitionEntityRow(item.Guid, item.Guid.ToString("N")[..8], "item", TreeSidebarNode.Icons.Item, EntityType.Item));
                    _entityItems.Sort((a, b) => string.Compare(a.Title, b.Title, StringComparison.OrdinalIgnoreCase));
                }
            }
            else
            {
                _entityListError = result.Error?.Detail ?? "Failed to add item.";
            }
        }
        catch (FargoSdkApiException ex)
        {
            _entityListError = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to add item." : ex.Message;
        }
    }

    private async Task AddUserAsync(User user)
    {
        _addUserOpen = false;
        if (!EntityGuid.HasValue) return;

        try
        {
            var result = await user.AddPartitionAsync(EntityGuid.Value);
            if (result.IsSuccess)
            {
                if (!_entityItems.Any(r => r.EntityGuid == user.Guid))
                {
                    _entityItems.Add(new PartitionEntityRow(user.Guid, user.Nameid, "user", TreeSidebarNode.Icons.User, EntityType.User));
                    _entityItems.Sort((a, b) => string.Compare(a.Title, b.Title, StringComparison.OrdinalIgnoreCase));
                }
            }
            else
            {
                _entityListError = result.Error?.Detail ?? "Failed to add user.";
            }
        }
        catch (FargoSdkApiException ex)
        {
            _entityListError = string.IsNullOrWhiteSpace(ex.Message) ? "Failed to add user." : ex.Message;
        }
    }

    private async Task SaveAsync()
    {
        if (_partition is null) return;

        await _save.RunAsync(async () =>
        {
            Guid? movedToParent = null;

            if (!_isGlobal && (_edit.ParentGuid ?? "") != (_origParent ?? ""))
            {
                Guid? newParent = string.IsNullOrWhiteSpace(_edit.ParentGuid)
                    ? null
                    : Guid.TryParse(_edit.ParentGuid, out var parsed) ? parsed : null;

                if (newParent is null && !string.IsNullOrWhiteSpace(_edit.ParentGuid))
                {
                    throw new InvalidOperationException("Parent partition GUID is not valid.");
                }

                var moveResult = await _partition.MoveAsync(newParent!.Value);
                if (!moveResult.IsSuccess)
                {
                    throw new InvalidOperationException(moveResult.Error?.Detail ?? "Failed to move partition.");
                }

                movedToParent = newParent;
            }

            await _partition.UpdateAsync(p =>
            {
                if (!_isGlobal && _edit.Name is not null)
                    p.Name = _edit.Name;
                p.Description = _edit.Description ?? string.Empty;
                p.IsActive = _edit.IsActive;
            });

            if (movedToParent.HasValue)
            {
                _tree?.NotifyMoved(EntityGuid!.Value, movedToParent.Value);
                _allEntitiesTree?.NotifyMoved(EntityGuid!.Value, movedToParent.Value);
            }

            _tree?.NotifyUpdated(EntityGuid!.Value, _edit.Name ?? _partition.Name, _edit.IsActive);
            _allEntitiesTree?.NotifyUpdated(EntityGuid!.Value, _edit.Name ?? _partition.Name, _edit.IsActive);

            await LoadAsync();
        }, "Failed to save.");
    }

    private void OpenCreate()
    {
        _createForm = new CreateForm();
        _create.Clear();
        _createOpen = true;
    }

    private async Task CreateAsync()
    {
        var ok = await _create.RunAsync(async () =>
        {
            var parentGuid = EntityGuid;
            var partition = await Engine.Partitions.CreateAsync(
                _createForm.Name!,
                parentPartitionGuid: parentGuid);

            _tree?.NotifyCreated(partition.Guid, partition.Name, partition.IsActive, parentGuid);
            _allEntitiesTree?.NotifyCreated(partition.Guid, partition.Name, partition.IsActive, parentGuid);
            Navigation.NavigateTo($"/entities/partitions/{partition.Guid}");
        }, "Failed to create.");

        if (ok) _createOpen = false;
    }

    private void OpenDelete()
    {
        _delete.Clear();
        _deleteOpen = true;
    }

    private async Task DeleteAsync()
    {
        if (!EntityGuid.HasValue) return;

        var ok = await _delete.RunAsync(async () =>
        {
            var deletedGuid = EntityGuid.Value;
            await Engine.Partitions.DeleteAsync(deletedGuid);
            _tree?.NotifyDeleted(deletedGuid);
            _allEntitiesTree?.NotifyDeleted(deletedGuid);
            Navigation.NavigateTo("/entities/partitions");
        }, "Failed to delete.");

        if (ok) _deleteOpen = false;
    }

    private enum EntityType { Article, Item, User }

    private sealed record PartitionEntityRow(Guid EntityGuid, string Title, string TypeLabel, string Icon, EntityType Type);

    private sealed class EditModel
    {
        [Required(ErrorMessage = "Name is required.")]
        [StringLength(100, MinimumLength = 3, ErrorMessage = "Name must be between 3 and 100 characters.")]
        public string? Name { get; set; }
        public string? Description { get; set; }
        public string? ParentGuid { get; set; }
        public bool IsActive { get; set; }
    }

    private sealed class CreateForm
    {
        [Required(ErrorMessage = "Name is required.")]
        public string? Name { get; set; }
    }
}
