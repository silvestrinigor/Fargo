FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

COPY Fargo.slnx ./
COPY src/Fargo.Web/Fargo.Web.csproj src/Fargo.Web/
COPY src/Fargo.WebComponents/Fargo.WebComponents.csproj src/Fargo.WebComponents/
COPY src/Fargo.ServiceDefaults/Fargo.ServiceDefaults.csproj src/Fargo.ServiceDefaults/

RUN dotnet restore src/Fargo.Web/Fargo.Web.csproj

COPY . .

WORKDIR /src/src/Fargo.Web
RUN dotnet publish Fargo.Web.csproj -c Release -o /app/publish /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS final
WORKDIR /app

COPY --from=build /app/publish .

ENV ASPNETCORE_URLS=http://+:8081
EXPOSE 8081

ENTRYPOINT ["dotnet", "Fargo.Web.dll"]